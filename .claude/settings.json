{
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true
  },
  "skills": {
    "canvas-v2": {
      "description": "Design and implement v2 animation styles",
      "path": ".claude/skills/canvas-v2.md"
    },
    "canvas-harden": {
      "description": "Security and reliability audit",
      "path": ".claude/skills/canvas-harden.md"
    },
    "canvas-test": {
      "description": "Add test suite for canvas features",
      "path": ".claude/skills/canvas-test.md"
    },
    "canvas-cache": {
      "description": "Intelligent caching with KV",
      "path": ".claude/skills/canvas-cache.md"
    },
    "canvas-translate": {
      "description": "Portuguese translations audit",
      "path": ".claude/skills/canvas-translate.md"
    },
    "canvas-pricing": {
      "description": "Advanced Stripe monetization",
      "path": ".claude/skills/canvas-pricing.md"
    },
    "canvas-seo": {
      "description": "Search optimization audit",
      "path": ".claude/skills/canvas-seo.md"
    },
    "canvas-video-export": {
      "description": "MP4/WebM video export",
      "path": ".claude/skills/canvas-video-export.md"
    },
    "canvas-embed": {
      "description": "Embeddable widget for third-party sites",
      "path": ".claude/skills/canvas-embed.md"
    },
    "canvas-analytics": {
      "description": "Usage tracking and analytics",
      "path": ".claude/skills/canvas-analytics.md"
    },
    "resume-review": {
      "description": "Resume page review and improvements",
      "path": ".claude/skills/resume-review.md"
    },
    "create-new-post-based-on-last-commit": {
      "description": "Write a blog post (EN + PT-BR) based on recent commits",
      "path": ".claude/skills/create-new-post-based-on-last-commit.md"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-session-state.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-phase-boundary.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-read-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-validate-commit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  }
}
