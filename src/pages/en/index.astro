---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
---

<BaseLayout title="Gabriel Rodrigues - Senior Frontend Engineer">
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-16">
    <p class="text-accent font-medium mb-2">{t('hero.greeting')}</p>
    <h1 class="text-4xl sm:text-5xl font-bold text-text-primary mb-4">
      {t('hero.name')}
    </h1>
    <p class="text-xl text-text-secondary mb-2">{t('hero.title')}</p>
    <p class="text-text-muted max-w-xl mb-8">{t('hero.subtitle')}</p>
    <div class="flex gap-4 flex-wrap">
      <a
        href="/en/resume/"
        class="px-6 py-2.5 bg-accent text-white rounded-lg font-medium hover:bg-accent-hover transition-colors"
      >
        {t('hero.cta.resume')}
      </a>
      <a
        href="/en/blog/"
        class="px-6 py-2.5 border border-border text-text-secondary rounded-lg font-medium hover:border-accent hover:text-accent transition-colors"
      >
        {t('hero.cta.blog')}
      </a>
    </div>
  </section>

  <!-- Highlights -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-text-primary mb-8">{t('home.highlights.title')}</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
      <div class="text-center p-6 rounded-lg border border-border bg-bg-card">
        <p class="text-3xl font-bold text-accent">{t('home.highlights.years')}</p>
        <p class="text-sm text-text-muted mt-1">{t('home.highlights.years.label')}</p>
      </div>
      <div class="text-center p-6 rounded-lg border border-border bg-bg-card">
        <p class="text-3xl font-bold text-accent">{t('home.highlights.brands')}</p>
        <p class="text-sm text-text-muted mt-1">{t('home.highlights.brands.label')}</p>
      </div>
      <div class="text-center p-6 rounded-lg border border-border bg-bg-card">
        <p class="text-3xl font-bold text-accent">{t('home.highlights.bugs')}</p>
        <p class="text-sm text-text-muted mt-1">{t('home.highlights.bugs.label')}</p>
      </div>
      <div class="text-center p-6 rounded-lg border border-border bg-bg-card">
        <p class="text-3xl font-bold text-accent">{t('home.highlights.efficiency')}</p>
        <p class="text-sm text-text-muted mt-1">{t('home.highlights.efficiency.label')}</p>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-text-primary mb-4">{t('home.about.title')}</h2>
    <p class="text-text-secondary leading-relaxed max-w-2xl">{t('home.about.text')}</p>
  </section>
</BaseLayout>
