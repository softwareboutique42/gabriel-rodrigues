---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');
const allPosts = await getCollection('blog', ({ data }) => data.lang === 'en');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog - Gabriel Rodrigues">
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-8">
    <h1 class="text-3xl font-bold text-text-primary mb-2">{t('blog.title')}</h1>
    <p class="text-text-secondary mb-10">{t('blog.subtitle')}</p>
    {
      posts.length === 0 ? (
        <p class="text-text-muted">{t('blog.noPosts')}</p>
      ) : (
        <div class="grid gap-6">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id.replace('en/', '')}
              tags={post.data.tags}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
