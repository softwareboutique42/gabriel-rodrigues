---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import AdUnit from '../../../components/AdUnit.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');
const allPosts = await getCollection('blog', ({ data }) => data.lang === 'en');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function getReadingTime(body: string | undefined): number {
  const words = (body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}
---

<BaseLayout
  title="Blog - Gabriel Rodrigues"
  description="Thoughts on frontend engineering, Vue, Angular, TypeScript, testing, and web performance by Gabriel Rodrigues."
>
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-8">
    <h1
      class="text-4xl font-bold text-text-primary tracking-tight mb-2"
      style="letter-spacing: -0.03em;"
    >
      {t('blog.title')}
    </h1>
    <p class="text-text-muted font-mono text-sm mb-8">{t('blog.subtitle')}</p>
    <div class="mb-8">
      <label for="blog-search" class="sr-only">{t('blog.searchPlaceholder')}</label>
      <input
        id="blog-search"
        type="search"
        placeholder={t('blog.searchPlaceholder')}
        autocomplete="off"
        class="w-full bg-surface-container border border-border px-4 py-2 font-mono text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-neon transition-colors"
      />
    </div>
    {
      posts.length === 0 ? (
        <p class="text-text-muted font-mono text-sm">{t('blog.noPosts')}</p>
      ) : (
        <div class="grid gap-4">
          {posts.map((post) => (
            <div data-post data-slug={post.id.replace('en/', '').replace('.md', '')}>
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                slug={post.id.replace('en/', '')}
                tags={post.data.tags}
                readingTime={getReadingTime(post.body)}
              />
            </div>
          ))}
        </div>
      )
    }
    <p id="search-empty" class="hidden font-mono text-sm text-text-muted">{t('blog.noResults')}</p>
    <AdUnit format="horizontal" />
  </section>
</BaseLayout>

<script>
  import { setupBlogSearch } from '../../../scripts/blog-search';
  document.addEventListener('astro:page-load', () => setupBlogSearch('/en/blog-index.json'));
</script>
