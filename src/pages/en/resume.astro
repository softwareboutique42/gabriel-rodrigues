---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperienceCard from '../../components/ExperienceCard.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
---

<BaseLayout title="Resume - Gabriel Rodrigues">
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-8">
    <div class="flex items-center justify-between mb-10">
      <h1
        class="text-4xl font-bold text-text-primary tracking-tight"
        style="letter-spacing: -0.03em;"
      >
        {t('resume.title')}
      </h1>
      <a
        href="/resume.pdf"
        target="_blank"
        class="clip-corners hover-glitch px-5 py-2.5 bg-neon text-neon-on text-xs font-bold uppercase tracking-wider flex items-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path></svg
        >
        {t('resume.download')}
      </a>
    </div>

    <!-- Summary -->
    <div class="mb-16 glow-panel p-6">
      <p class="text-text-secondary leading-relaxed">
        Senior Frontend Engineer with 10+ years shipping high-scale web applications across iGaming,
        SaaS, and fintech platforms serving millions of users. Proven impact: 60% bug reduction via
        Playwright E2E automation, 22% registration uplift through A/B-tested UX, and
        enterprise-grade Angular/Vue solutions deployed across 28+ international brands. Led teams
        of up to 12 engineers, championed web security (CSP, XSS prevention), and drove performance
        optimization and accessibility (WCAG) across regulated, high-traffic platforms.
      </p>
    </div>

    <!-- Experience -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-8">
      {t('resume.experience')}
    </h2>
    <div class="mb-16">
      <ExperienceCard
        company="The Mill Adventure"
        role="Senior Frontend Software Engineer"
        period="Jul 2024 - Present"
        location="Malta"
        achievements={[
          'Drove 20% reduction in Customer Support resolution time by architecting automated KYC flows with BankID/Smart ID, eliminating manual document verification.',
          'Reduced post-release bugs by 60% by building Playwright E2E suite covering all critical paths, integrated into CI/CD for automated regression.',
          'Eliminated XSS vulnerability surface by enforcing strict Content Security Policy (CSP) and refactoring unsafe DOM manipulations into sanitized methods.',
          'Spearheaded backoffice redesign in Angular 17 and Angular Material, cutting average task completion time by 35% for internal operations teams.',
          'Coached 4 backend-oriented engineers on TypeScript patterns and component architecture, reducing frontend PR review cycles by 40%.',
        ]}
      />
      <ExperienceCard
        company="Deskhero"
        role="Senior Frontend Software Engineer"
        period="Aug 2023 - May 2024"
        location="Torrevieja, Spain"
        achievements={[
          'Architected 52-component Storybook library with Chromatic visual regression, reducing feature development cycles by 2 months.',
          'Engineered automated release pipeline with semantic-release and Commitizen, eliminating manual versioning errors across all deployments.',
          'Mentored 3 engineers on Vue 3 Composition API, Pinia, and Jest unit testing, accelerating onboarding from 4 weeks to 2 weeks.',
        ]}
      />
      <ExperienceCard
        company="Betsson Group"
        role="Senior Frontend Software Engineer"
        period="Mar 2021 - Aug 2023"
        location="Malta"
        achievements={[
          'Delivered KYC, Onboarding, and Compliance features in Angular and Stencil.js deployed across 28+ iGaming brands in regulated European markets.',
          'Maintained 99.9% uptime during peak events (World Cup Final, 10x normal traffic) through on-call incident management and rapid hotfix deployment.',
          'Led 10-person engineering team as Team Captain for 12 months, increasing sprint velocity by 25% through process optimization.',
          'Mentored 5 junior/mid developers on TypeScript and GraphQL, reducing average PR turnaround from 3 days to 1 day.',
        ]}
      />
      <ExperienceCard
        company="Ancient Gaming"
        role="Senior Frontend Software Engineer"
        period="Jul 2020 - Jan 2021"
        location="Malta"
        achievements={[
          'Engineered redesigned registration flow in Angular, achieving 22% registration increase validated via A/B testing and Google Analytics.',
          'Redesigned lobby and filtering system with responsive components, driving 14% increase in mobile unboxing conversions (A/B validated).',
          'Integrated Zendesk support tooling and revamped FAQ, reducing average Customer Service response time by 30%.',
        ]}
      />
      <ExperienceCard
        company="XCaliber"
        role="Senior Frontend Software Engineer"
        period="Sep 2018 - Jul 2020"
        location="St Julians, Malta"
        achievements={[
          'Architected Angular web applications for 4 iGaming brands (sunmaker.com, cherrycasino.com, manekichi.com, norgesspill.com) serving millions of users.',
          'Designed multi-tenant frontend architecture with RESTful API integration, enabling new brand launches in under 2 weeks versus 2 months previously.',
        ]}
      />
      <ExperienceCard
        company="Virtua Software"
        role="Full Stack Engineer"
        period="Feb 2014 - Jun 2018"
        location="Goiania, Brazil"
        achievements={[
          'Created Virtua Web, a self-service debt negotiation platform serving 500K+ users — subsequently adopted by Bank of Brasil and Caixa Economica Federal.',
          'Led 12-person development team, training interns and establishing coding standards across JavaScript, PHP, and Bootstrap projects.',
        ]}
      />
    </div>

    <!-- Skills -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.skills')}
    </h2>
    <div class="mb-16 space-y-4">
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">Languages</p>
        <div class="flex flex-wrap gap-2">
          {
            ['TypeScript', 'JavaScript', 'HTML5', 'CSS3', 'SCSS', 'GraphQL'].map((skill) => (
              <span
                class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
              >
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">Frameworks</p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'Angular',
              'Vue 3',
              'Stencil.js',
              'Web Components',
              'Angular Material',
              'Tailwind CSS',
              'Node.js',
            ].map((skill) => (
              <span
                class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
              >
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">Testing</p>
        <div class="flex flex-wrap gap-2">
          {
            ['Playwright', 'Jest', 'Vitest', 'Storybook', 'Chromatic', 'A/B Testing'].map(
              (skill) => (
                <span
                  class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                  style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
                >
                  {skill}
                </span>
              ),
            )
          }
        </div>
      </div>
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">
          Tools & Practices
        </p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'Git',
              'CI/CD',
              'Docker',
              'Vite',
              'Pinia',
              'REST APIs',
              'Semantic Release',
              'Performance Optimization',
              'Accessibility (WCAG)',
              'Responsive Design',
              'Micro-frontends',
              'Design Systems',
            ].map((skill) => (
              <span
                class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
              >
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">Methodologies</p>
        <div class="flex flex-wrap gap-2">
          {
            ['Agile/Scrum', 'Code Review', 'Mentorship', 'Team Leadership'].map((skill) => (
              <span
                class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
              >
                {skill}
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Education -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.education')}
    </h2>
    <div class="mb-16 glow-panel p-6">
      <h3 class="font-bold text-text-primary">Pontificia Universidade Catolica de Goias</h3>
      <p class="text-neon font-mono text-sm mt-1">
        System Analysis and Development, Computer Software Engineering
      </p>
      <p class="text-xs text-text-muted font-mono mt-1 tracking-wider">2014 - 2018</p>
    </div>

    <!-- Languages -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.languages')}
    </h2>
    <div class="glow-panel p-6 flex gap-8">
      <div>
        <p class="text-text-primary font-medium">English</p>
        <p class="text-xs text-text-muted font-mono mt-1">Professional Working</p>
      </div>
      <div>
        <p class="text-text-primary font-medium">Portuguese</p>
        <p class="text-xs text-text-muted font-mono mt-1">Native</p>
      </div>
    </div>
  </section>
</BaseLayout>
