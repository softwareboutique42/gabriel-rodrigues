---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperienceCard from '../../components/ExperienceCard.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
---

<BaseLayout title="Resume - Gabriel Rodrigues">
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-8">
    <div class="flex items-center justify-between mb-10">
      <h1
        class="text-4xl font-bold text-text-primary tracking-tight"
        style="letter-spacing: -0.03em;"
      >
        {t('resume.title')}
      </h1>
      <a
        href="/resume.pdf"
        target="_blank"
        class="clip-corners hover-glitch px-5 py-2.5 bg-neon text-neon-on text-xs font-bold uppercase tracking-wider flex items-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path></svg
        >
        {t('resume.download')}
      </a>
    </div>

    <!-- Summary -->
    <div class="mb-16 glow-panel p-6">
      <p class="text-text-secondary leading-relaxed">
        Frontend Software Engineer with over 10 years of experience designing, building, and
        optimizing web applications for high-scale digital platforms across Europe and Latin
        America. Specialized in Angular, Vue, and TypeScript, with a strong focus on performance,
        security, and developer experience.
      </p>
    </div>

    <!-- Experience -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-8">
      {t('resume.experience')}
    </h2>
    <div class="mb-16">
      <ExperienceCard
        company="The Mill Adventure"
        role="Senior Frontend Software Engineer"
        period="Jul 2024 - Present"
        location="Malta"
        achievements={[
          'Boosted operational efficiency by driving a 20% reduction in Customer Support time through automated KYC implementation (BankID/Smart ID).',
          'Reduced post-release bugs by 60% by introducing Playwright for E2E critical path testing.',
          'Eliminated potential XSS vulnerabilities by implementing strict Content Security Policy (CSP) and refactoring unsafe DOM manipulations.',
          'Led complete backoffice redesign using Angular and Angular Material.',
        ]}
      />
      <ExperienceCard
        company="Deskhero"
        role="Senior Frontend Software Engineer"
        period="Aug 2023 - May 2024"
        location="Torrevieja, Spain"
        achievements={[
          'Built a proprietary Component Library using Storybook and Chromatic, standardizing UI and accelerating feature development.',
          'Implemented release process with semantic release and commitizen, ensuring smooth deployments.',
          'Mentored team members on modern frontend workflows and best practices.',
        ]}
      />
      <ExperienceCard
        company="Betsson Group"
        role="Senior Frontend Software Engineer"
        period="Mar 2021 - Aug 2023"
        location="Malta"
        achievements={[
          'Delivered core Angular and Stencil.js features for KYC, Onboarding and Compliance utilized by 28+ international iGaming brands.',
          'Managed on-call duties during critical high-traffic events (e.g., World Cup Final), ensuring platform stability.',
          'Served as Team Captain (Scrum Master equivalent) for one year, optimizing team delivery.',
        ]}
      />
      <ExperienceCard
        company="Ancient Gaming"
        role="Senior Frontend Software Engineer"
        period="Jul 2020 - Jan 2021"
        location="Malta"
        achievements={[
          'Led revamp of registration/login flows in Angular, achieving 22% increase in registrations (A/B tested).',
          'Redesigned lobby and filtering systems resulting in 14% increase in mobile unboxing.',
          'Integrated Zendesk support tooling improving customer service efficiency.',
        ]}
      />
      <ExperienceCard
        company="XCaliber"
        role="Senior Frontend Software Engineer"
        period="Sep 2018 - Jul 2020"
        location="St Julians, Malta"
        achievements={[
          'Developed scalable web applications using Angular for brands like sunmaker.com, cherrycasino.com, manekichi.com, and norgesspill.com.',
          'Designed flexible, reusable frontend architectures integrated with RESTful APIs and microservices.',
        ]}
      />
      <ExperienceCard
        company="Virtua Software"
        role="Full Stack Engineer"
        period="Feb 2014 - Jun 2018"
        location="Goiania, Brazil"
        achievements={[
          'Built and managed systems using JavaScript, jQuery, Bootstrap, and PHP.',
          'Created Virtua Web - a debt negotiation platform so successful it was later adopted by Bank of Brasil and Caixa Economica Federal.',
          'Trained interns and led the web development team.',
        ]}
      />
    </div>

    <!-- Skills -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.skills')}
    </h2>
    <div class="mb-16 flex flex-wrap gap-2">
      {
        [
          'Angular',
          'Vue',
          'TypeScript',
          'JavaScript',
          'GraphQL',
          'REST APIs',
          'Playwright',
          'Storybook',
          'Stencil.js',
          'Vite',
          'Pinia',
          'Angular Material',
          'Tailwind CSS',
          'SCSS',
          'HTML5',
          'CSS3',
          'Git',
          'CI/CD',
          'Agile/Scrum',
        ].map((skill) => (
          <span
            class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
            style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
          >
            {skill}
          </span>
        ))
      }
    </div>

    <!-- Education -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.education')}
    </h2>
    <div class="mb-16 glow-panel p-6">
      <h3 class="font-bold text-text-primary">Pontificia Universidade Catolica de Goias</h3>
      <p class="text-neon font-mono text-sm mt-1">
        System Analysis and Development, Computer Software Engineering
      </p>
      <p class="text-xs text-text-muted font-mono mt-1 tracking-wider">2014 - 2018</p>
    </div>

    <!-- Certifications -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.certifications')}
    </h2>
    <div class="mb-16 glow-panel p-6">
      <p class="text-text-secondary">Basics of Scrum, Agile and Project Delivery</p>
    </div>

    <!-- Publications -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.publications')}
    </h2>
    <div class="glow-panel p-6 space-y-3">
      <p class="text-text-secondary">
        jQuery Plugin For HTML5 Desktop Push Notifications - easyNotify.js
      </p>
      <p class="text-text-secondary">3 jQuery/JavaScript Plugins for Push Notifications</p>
    </div>
  </section>
</BaseLayout>
