---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');
---

<BaseLayout
  title="Slots - Gabriel Rodrigues"
  description="Slots shell foundation with bilingual in-development messaging and compliance notice."
>
  <section
    id="slots-shell-root"
    data-slots-seed="slots-phase-13-en"
    data-slots-label-state={t('slots.gameplay.label.state')}
    data-slots-label-outcome={t('slots.gameplay.label.outcome')}
    data-slots-label-seed={t('slots.gameplay.label.seed')}
    data-slots-msg-idle={t('slots.gameplay.status.idle')}
    data-slots-msg-spinning={t('slots.gameplay.status.spinning')}
    data-slots-msg-result={t('slots.gameplay.status.result')}
    data-slots-msg-insufficient={t('slots.gameplay.status.insufficient')}
    data-slots-msg-blocked-spinning={t('slots.gameplay.status.blockedSpinning')}
    data-slots-msg-pending={t('slots.gameplay.status.pending')}
    class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 sm:pt-20 pb-12 sm:pb-16"
  >
    <h1
      class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-1 sm:mb-2 ls-tight-3"
    >
      {t('slots.title')}
    </h1>
    <p class="text-text-muted font-mono text-xs sm:text-sm mb-8 sm:mb-10">{t('slots.subtitle')}</p>

    <article class="glow-panel p-5 sm:p-6">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span
          class="font-mono text-[10px] uppercase tracking-widest text-gold bg-gold-dim px-2 py-1"
        >
          {t('slots.badge.foundation')}
        </span>
        <span id="slots-shell-status" class="font-mono text-xs uppercase tracking-wider text-neon">
          {t('slots.status.inDevelopment')}
        </span>
      </div>

      <p class="text-sm text-text-secondary mb-6">{t('slots.description')}</p>

      <div class="border border-surface-container-high bg-surface-container p-4 sm:p-5 mb-6">
        <p class="font-mono text-xs uppercase tracking-widest text-text-muted mb-2">
          {t('slots.disclaimer.heading')}
        </p>
        <p class="text-sm text-text-secondary">{t('slots.disclaimer.noGambling')}</p>
        <p class="text-sm text-text-secondary mt-1">{t('slots.disclaimer.noRealMoney')}</p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a
          href="/en/projects/"
          class="clip-corners hover-glitch inline-block text-center px-5 py-2 bg-neon text-neon-on font-bold text-xs uppercase tracking-wider"
        >
          {t('slots.cta.projects')}
        </a>
        <a
          href="/en/canvas/"
          class="inline-block text-center px-5 py-2 border border-surface-container-high text-text-primary font-bold text-xs uppercase tracking-wider hover:text-neon transition-colors"
        >
          {t('slots.cta.canvas')}
        </a>
      </div>

      <div id="slots-gameplay" class="mt-6 border border-surface-container-high p-4 sm:p-5">
        <p class="font-mono text-xs uppercase tracking-wider text-text-muted mb-2">
          {t('slots.gameplay.panel.title')}
        </p>
        <div class="flex flex-wrap items-center gap-2 mb-3 text-xs">
          <span class="text-text-muted">{t('slots.gameplay.label.balance')}:</span>
          <strong id="slots-balance-value" class="text-neon">40</strong>
          <span class="text-text-muted ml-4">{t('slots.gameplay.label.bet')}:</span>
          <button
            id="slots-bet-dec"
            type="button"
            class="min-h-11 min-w-11 px-2 py-1 border border-surface-container-high text-text-primary"
          >
            -
          </button>
          <strong id="slots-bet-value" class="text-cyan">2</strong>
          <button
            id="slots-bet-inc"
            type="button"
            class="min-h-11 min-w-11 px-2 py-1 border border-surface-container-high text-text-primary"
          >
            +
          </button>
        </div>
        <div class="flex flex-wrap items-center gap-3 mb-3">
          <button
            id="slots-spin-button"
            data-slots-action="spin"
            type="button"
            class="clip-corners inline-block text-center px-4 py-2 bg-cyan text-background font-bold text-xs uppercase tracking-wider"
          >
            {t('slots.gameplay.cta.spin')}
          </button>
          <p id="slots-gameplay-status" class="font-mono text-xs text-text-muted">
            {t('slots.gameplay.label.state')}: {t('slots.gameplay.status.idle')}
          </p>
        </div>
        <p id="slots-gameplay-outcome" class="text-sm text-text-secondary">
          {t('slots.gameplay.label.outcome')}: {t('slots.gameplay.status.pending')}
        </p>
        <p id="slots-gameplay-seed" class="text-xs text-text-muted mt-1">
          {t('slots.gameplay.label.seed')}: -
        </p>
        <pre
          id="slots-round-result"
          data-slots-result
          class="mt-3 p-3 text-xs overflow-x-auto max-w-full border border-surface-container-high bg-background/50 break-all sm:break-normal">
        </pre>
      </div>
    </article>
  </section>

  <script>
    import { initSlotsShell } from '../../../scripts/slots/main';

    document.addEventListener('astro:page-load', () => {
      if (document.getElementById('slots-shell-root')) {
        initSlotsShell();
      }
    });
  </script>
</BaseLayout>
