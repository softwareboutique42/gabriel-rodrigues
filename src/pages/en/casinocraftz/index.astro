---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');
---

<BaseLayout
  title="Casinocraftz - Gabriel Rodrigues"
  description="Transparent browser-first educational casino simulation. Zero-risk, zero real money. Pure game math literacy."
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 sm:pt-20 pb-12 sm:pb-16">
    <article
      class="glow-panel p-6 sm:p-8"
      data-casinocraftz-shell-root
      data-casinocraftz-lang="en"
      data-casinocraftz-current-lesson="house-edge"
      data-casinocraftz-tutorial-step="welcome"
      data-casinocraftz-essence="0"
      data-casinocraftz-essence-label={t('tutorial.essence.label')}
      data-casinocraftz-lesson-status-active={t('tutorial.lesson.status.active')}
      data-casinocraftz-lesson-status-complete={t('tutorial.lesson.status.complete')}
      data-casinocraftz-lesson-status-locked={t('tutorial.lesson.status.locked')}
      data-casinocraftz-lesson-open-label={t('tutorial.lesson.cta.open')}
      data-casinocraftz-lesson-review-label={t('tutorial.lesson.cta.review')}
      data-casinocraftz-lesson-preview-label={t('tutorial.lesson.cta.preview')}
      data-casinocraftz-lesson-house-edge-label={t('tutorial.lesson.houseEdge.label')}
      data-casinocraftz-lesson-house-edge-description={t('tutorial.lesson.houseEdge.description')}
      data-casinocraftz-lesson-near-miss-label={t('tutorial.lesson.nearMiss.label')}
      data-casinocraftz-lesson-near-miss-description={t('tutorial.lesson.nearMiss.description')}
      data-casinocraftz-lesson-sensory-conditioning-soon={t(
        'tutorial.lesson.sensoryConditioning.soon',
      )}
      data-casinocraftz-curriculum-progress-title={t('tutorial.curriculum.progressTitle')}
      data-casinocraftz-curriculum-bounded-rule={t('tutorial.curriculum.boundedRule')}
      data-casinocraftz-lesson-sensory-conditioning-label={t(
        'tutorial.lesson.sensoryConditioning.label',
      )}
      data-casinocraftz-lesson-sensory-conditioning-description={t(
        'tutorial.lesson.sensoryConditioning.description',
      )}
      data-casinocraftz-cards-title="Utility Cards"
      data-casinocraftz-activate-label={t('tutorial.cta.activateCard')}
      data-casinocraftz-replay-label={t('tutorial.cta.revisitLesson')}
      data-casinocraftz-recap-label={t('tutorial.cta.whyTransition')}
      data-casinocraftz-causality-probability-reveal={t('tutorial.causality.probabilityReveal')}
      data-casinocraftz-causality-near-miss-reveal={t('tutorial.causality.nearMissReveal')}
      data-casinocraftz-causality-sensory-reveal={t('tutorial.causality.sensoryReveal')}
      data-casinocraftz-step-welcome-label={t('tutorial.step.welcome.label')}
      data-casinocraftz-step-house-edge-intro-label={t('tutorial.step.houseEdgeIntro.label')}
      data-casinocraftz-step-play-and-observe-label={t('tutorial.step.playAndObserve.label')}
      data-casinocraftz-step-probability-reveal-label={t('tutorial.step.probabilityReveal.label')}
      data-casinocraftz-step-card-unlock-label={t('tutorial.step.cardUnlock.label')}
      data-casinocraftz-step-complete-label={t('tutorial.step.complete.label')}
      data-casinocraftz-step-near-miss-intro-label={t('tutorial.step.nearMissIntro.label')}
      data-casinocraftz-step-near-miss-observe-label={t('tutorial.step.nearMissObserve.label')}
      data-casinocraftz-step-near-miss-reveal-label={t('tutorial.step.nearMissReveal.label')}
      data-casinocraftz-step-near-miss-complete-label={t('tutorial.step.nearMissComplete.label')}
      data-casinocraftz-step-sensory-conditioning-intro-label={t(
        'tutorial.step.sensoryConditioningIntro.label',
      )}
      data-casinocraftz-step-sensory-conditioning-observe-label={t(
        'tutorial.step.sensoryConditioningObserve.label',
      )}
      data-casinocraftz-step-sensory-conditioning-reveal-label={t(
        'tutorial.step.sensoryConditioningReveal.label',
      )}
      data-casinocraftz-step-sensory-conditioning-complete-label={t(
        'tutorial.step.sensoryConditioningComplete.label',
      )}
      data-casinocraftz-card-status-locked={t('cards.status.locked')}
      data-casinocraftz-card-status-unlocked={t('cards.status.unlocked')}
      data-casinocraftz-card-probability-seer-label={t('cards.probabilitySeer.label')}
      data-casinocraftz-card-probability-seer-description={t('cards.probabilitySeer.description')}
      data-casinocraftz-card-dopamine-dampener-label={t('cards.dopamineDampener.label')}
      data-casinocraftz-card-dopamine-dampener-description={t('cards.dopamineDampener.description')}
      data-casinocraftz-card-house-edge-label={t('cards.houseEdge.label')}
      data-casinocraftz-card-house-edge-description={t('cards.houseEdge.description')}
    >
      <!-- LOBBY HEADER -->
      <header
        class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8 sm:mb-10"
        data-casinocraftz-zone="foundation"
      >
        <div>
          <p class="font-mono text-xs text-cyan uppercase tracking-widest mb-3">
            {t('casinocraftz.badge.liveLab')}
          </p>
          <h1
            class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-3 ls-tight-3"
          >
            {t('casinocraftz.title')}
          </h1>
          <p class="text-sm text-text-secondary max-w-2xl">
            {t('casinocraftz.disclaimer.zeroRisk')}
          </p>
        </div>

        <!-- WALLET HUD -->
        <div
          class="flex-shrink-0 hud-outline-subtle p-4 flex flex-col items-end gap-2 min-w-[160px]"
        >
          <p class="font-mono text-[10px] uppercase tracking-widest text-text-muted">
            {t('lobby.balance.label')}
          </p>
          <p class="font-mono text-2xl font-bold text-neon leading-none">
            <span data-ccz-lobby-balance>100</span>
          </p>
          <button
            data-ccz-deposit-trigger
            class="clip-corners hover-glitch inline-flex items-center justify-center min-h-8 px-3 py-1 bg-gold text-bg font-bold text-xs uppercase tracking-wider"
          >
            {t('lobby.deposit.trigger')}
          </button>
        </div>
      </header>

      <!-- GAME LOBBY GRID -->
      <section class="mb-8 sm:mb-10" data-casinocraftz-zone="games">
        <p class="font-mono text-xs text-gold uppercase tracking-widest mb-4">Game Lobby</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- Slots — LIVE -->
          <div
            class="hud-outline-subtle p-5 flex flex-col gap-3"
            data-ccz-game-card="slots"
            data-casinocraftz-slots-card
          >
            <div class="flex items-center justify-between">
              <p class="font-mono text-xs text-neon uppercase tracking-wider">
                {t('lobby.game.slots.label')}
              </p>
              <span class="font-mono text-[10px] uppercase tracking-wider text-cyan">Live</span>
            </div>
            <p class="text-xs text-text-muted flex-1">{t('lobby.game.slots.description')}</p>
            <a
              href="/en/slots/"
              data-casinocraftz-slots-link
              class="clip-corners hover-glitch inline-flex items-center justify-center min-h-9 px-4 py-1.5 bg-neon text-neon-on font-bold text-xs uppercase tracking-wider"
            >
              {t('lobby.game.slots.cta')} →
            </a>
          </div>

          <!-- Blackjack — LOCKED -->
          <div
            class="hud-outline-subtle p-5 flex flex-col gap-3 opacity-50"
            data-ccz-game-card="blackjack"
            aria-disabled="true"
          >
            <div class="flex items-center justify-between">
              <p class="font-mono text-xs text-text-muted uppercase tracking-wider">
                {t('lobby.game.blackjack.label')}
              </p>
              <span class="font-mono text-[10px] uppercase tracking-wider text-text-muted"
                >Locked</span
              >
            </div>
            <p class="text-xs text-text-muted flex-1">{t('lobby.game.blackjack.description')}</p>
            <button
              disabled
              aria-disabled="true"
              class="inline-flex items-center justify-center min-h-9 px-4 py-1.5 border border-surface-container-high text-text-muted font-mono text-xs uppercase tracking-wider cursor-not-allowed"
            >
              {t('lobby.game.locked.cta')}
            </button>
          </div>

          <!-- Roulette — LOCKED -->
          <div
            class="hud-outline-subtle p-5 flex flex-col gap-3 opacity-50"
            data-ccz-game-card="roulette"
            aria-disabled="true"
          >
            <div class="flex items-center justify-between">
              <p class="font-mono text-xs text-text-muted uppercase tracking-wider">Roulette</p>
              <span class="font-mono text-[10px] uppercase tracking-wider text-text-muted"
                >Locked</span
              >
            </div>
            <p class="text-xs text-text-muted flex-1">
              Zero-pockets, probability math, and the gambler's fallacy deconstructed.
            </p>
            <button
              disabled
              aria-disabled="true"
              class="inline-flex items-center justify-center min-h-9 px-4 py-1.5 border border-surface-container-high text-text-muted font-mono text-xs uppercase tracking-wider cursor-not-allowed"
            >
              {t('lobby.game.locked.cta')}
            </button>
          </div>
        </div>
      </section>

      <!-- CURRICULUM -->
      <section
        class="mt-6 sm:mt-8 hud-outline-subtle p-4 sm:p-6"
        data-casinocraftz-zone="curriculum"
      >
        <header class="mb-4">
          <p class="font-mono text-xs text-gold uppercase tracking-widest mb-1">
            {t('tutorial.curriculum.title')}
          </p>
          <p class="text-sm text-text-secondary max-w-2xl">
            {t('tutorial.curriculum.subtitle')}
          </p>
          <p class="text-xs text-text-muted mt-2" data-casinocraftz-curriculum-progress></p>
        </header>
        <div data-casinocraftz-curriculum></div>
      </section>

      <!-- TUTORIAL DIALOGUE -->
      <section class="mt-6 sm:mt-8 hud-outline-subtle p-4 sm:p-6" data-casinocraftz-zone="tutorial">
        <header class="mb-4">
          <p
            class="font-mono text-xs text-cyan uppercase tracking-widest mb-1"
            data-casinocraftz-step-label
          >
            {t('tutorial.step.welcome.label')}
          </p>
          <p
            class="font-mono text-xs text-neon uppercase tracking-wider"
            data-casinocraftz-essence-display
          >
            {t('tutorial.essence.label')}: 0
          </p>
        </header>
        <div data-casinocraftz-dialogue class="space-y-3 mb-4"></div>
        <button
          data-casinocraftz-tutorial-next
          class="clip-corners hover-glitch inline-flex items-center justify-center min-h-9 px-4 py-1.5 bg-cyan text-bg font-bold text-xs uppercase tracking-wider"
        >
          {t('tutorial.cta.nextStep')}
        </button>
        <button
          data-casinocraftz-tutorial-skip
          class="ml-3 inline-flex items-center justify-center min-h-9 px-4 py-1.5 text-text-muted font-mono text-xs hover:text-neon transition-colors"
        >
          {t('tutorial.cta.skipTutorial')}
        </button>

        <div class="mt-6 space-y-3">
          <div class="flex items-center justify-between gap-3 flex-wrap">
            <p class="font-mono text-[10px] uppercase tracking-widest text-gold">
              Live observation rig
            </p>
            <a
              href="/en/slots/"
              class="font-mono text-[11px] uppercase tracking-wider text-cyan hover:text-neon transition-colors"
            >
              Open standalone →
            </a>
          </div>
          <div class="hud-outline-subtle overflow-hidden bg-bg/70">
            <iframe
              data-casinocraftz-slots-embed
              src="/en/slots/?host=casinocraftz"
              title="Casinocraftz Slots Observation Rig"
              loading="eager"
              class="block w-full h-[780px] border-0 bg-bg"
            ></iframe>
          </div>
        </div>
      </section>

      <!-- UTILITY CARDS -->
      <section class="mt-4 sm:mt-6" data-casinocraftz-zone="cards">
        <p class="font-mono text-xs text-gold uppercase tracking-wider mb-3">Utility Cards</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div data-casinocraftz-card="probability-seer" class="hud-outline-subtle p-3">
            <p class="font-mono text-xs text-neon uppercase tracking-wider mb-1">
              {t('cards.probabilitySeer.label')}
            </p>
            <p class="text-xs text-text-muted mb-2">{t('cards.probabilitySeer.description')}</p>
            <button
              data-casinocraftz-card-activate="probability-seer"
              aria-disabled="true"
              class="font-mono text-xs text-text-muted uppercase tracking-wider"
            >
              {t('tutorial.cta.activateCard')}
            </button>
          </div>
          <div data-casinocraftz-card="dopamine-dampener" class="hud-outline-subtle p-3">
            <p class="font-mono text-xs text-neon uppercase tracking-wider mb-1">
              {t('cards.dopamineDampener.label')}
            </p>
            <p class="text-xs text-text-muted mb-2">{t('cards.dopamineDampener.description')}</p>
            <button
              data-casinocraftz-card-activate="dopamine-dampener"
              aria-disabled="true"
              class="font-mono text-xs text-text-muted uppercase tracking-wider"
            >
              {t('tutorial.cta.activateCard')}
            </button>
          </div>
          <div data-casinocraftz-card="house-edge" class="hud-outline-subtle p-3">
            <p class="font-mono text-xs text-neon uppercase tracking-wider mb-1">
              {t('cards.houseEdge.label')}
            </p>
            <p class="text-xs text-text-muted mb-2">{t('cards.houseEdge.description')}</p>
            <button
              data-casinocraftz-card-activate="house-edge"
              aria-disabled="true"
              class="font-mono text-xs text-text-muted uppercase tracking-wider"
            >
              {t('tutorial.cta.activateCard')}
            </button>
          </div>
        </div>
      </section>

      <!-- FOOTER ACTIONS -->
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 mt-6 sm:mt-8">
        <a
          href="/en/projects/"
          class="inline-flex items-center justify-center min-h-11 px-5 py-2 border border-surface-container-high text-text-primary font-bold text-xs uppercase tracking-wider hover:text-neon transition-colors"
        >
          {t('casinocraftz.cta.backProjects')}
        </a>
      </div>

      <!-- DEPOSIT MODAL -->
      <div
        data-ccz-deposit-modal
        hidden
        class="fixed inset-0 z-50 flex items-center justify-center p-4"
        style="background: rgba(0,0,0,0.75);"
      >
        <div
          role="dialog"
          aria-modal="true"
          aria-labelledby="ccz-deposit-title"
          class="glow-panel p-6 sm:p-8 w-full max-w-sm relative"
        >
          <button
            data-ccz-deposit-close
            class="absolute top-4 right-4 font-mono text-xs text-text-muted hover:text-neon transition-colors uppercase tracking-wider"
            aria-label="Close deposit modal"
          >
            ✕
          </button>

          <p class="font-mono text-xs text-gold uppercase tracking-widest mb-2">
            {t('lobby.deposit.title')}
          </p>
          <p id="ccz-deposit-title" class="text-xl font-bold text-text-primary mb-6">
            Select amount
          </p>

          <div class="grid grid-cols-3 gap-3 mb-6" data-ccz-deposit-amounts>
            <button
              data-ccz-deposit-amount="50"
              class="hud-outline-subtle p-3 font-mono text-sm font-bold text-text-primary hover:text-neon hover:border-neon transition-colors uppercase tracking-wider text-center"
            >
              50
            </button>
            <button
              data-ccz-deposit-amount="100"
              class="hud-outline-subtle p-3 font-mono text-sm font-bold text-text-primary hover:text-neon hover:border-neon transition-colors uppercase tracking-wider text-center"
            >
              100
            </button>
            <button
              data-ccz-deposit-amount="500"
              class="hud-outline-subtle p-3 font-mono text-sm font-bold text-text-primary hover:text-neon hover:border-neon transition-colors uppercase tracking-wider text-center"
            >
              500
            </button>
          </div>

          <div class="hud-outline-subtle p-3 mb-6 border-l-2 border-gold">
            <p class="font-mono text-[11px] text-gold uppercase tracking-wider mb-1">
              ⚠ Educational note
            </p>
            <p class="text-xs text-text-secondary">{t('lobby.deposit.educational')}</p>
          </div>

          <button
            data-ccz-deposit-confirm
            class="w-full clip-corners hover-glitch inline-flex items-center justify-center min-h-11 px-5 py-2 bg-neon text-neon-on font-bold text-xs uppercase tracking-wider"
          >
            {t('lobby.deposit.confirm')}
          </button>
        </div>
      </div>
    </article>
  </section>

  <script>
    import { mountTutorial } from '../../../scripts/casinocraftz/tutorial/main';
    import { mountLobby } from '../../../scripts/casinocraftz/lobby';

    document.addEventListener('astro:page-load', () => {
      const root = document.querySelector('[data-casinocraftz-shell-root]') as HTMLElement | null;
      if (!root) return;
      const lang = (root.dataset.casinocraftzLang ?? 'en') as 'en' | 'pt';
      mountLobby();
      mountTutorial({ lang });
    });
  </script>
</BaseLayout>
