---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');
---

<BaseLayout
  title="Projects - Gabriel Rodrigues"
  description="Discover active projects: Company Canvas and Slots foundation."
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 sm:pt-20 pb-12 sm:pb-16">
    <h1
      class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-1 sm:mb-2 ls-tight-3"
    >
      {t('projects.title')}
    </h1>
    <p class="text-text-muted font-mono text-xs sm:text-sm mb-8 sm:mb-10">
      {t('projects.subtitle')}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6">
      <article class="glow-panel p-5 sm:p-6 flex flex-col">
        <p class="font-mono text-xs text-neon uppercase tracking-widest mb-3">
          {t('projects.status.live')}
        </p>
        <h2 class="text-2xl font-bold text-text-primary tracking-tight mb-2">
          {t('canvas.title')}
        </h2>
        <p class="text-sm text-text-secondary mb-6">{t('projects.card.canvas.description')}</p>
        <a
          href="/en/canvas/"
          data-projects-analytics-target="canvas"
          data-projects-analytics-locale="en"
          data-projects-analytics-route="/en/projects/"
          class="mt-auto clip-corners hover-glitch inline-flex items-center justify-center min-h-11 text-center px-5 py-2 bg-neon text-neon-on font-bold text-xs uppercase tracking-wider"
        >
          {t('projects.card.canvas.cta')}
        </a>
      </article>

      <article class="glow-panel p-5 sm:p-6 flex flex-col">
        <p class="font-mono text-xs text-cyan uppercase tracking-widest mb-3">
          {t('projects.status.educationalLab')}
        </p>
        <h2 class="text-2xl font-bold text-text-primary tracking-tight mb-2">
          {t('casinocraftz.title')}
        </h2>
        <p class="text-sm text-text-secondary mb-6">
          {t('projects.card.casinocraftz.description')}
        </p>
        <a
          href="/en/casinocraftz/"
          data-projects-analytics-target="casinocraftz"
          data-projects-analytics-locale="en"
          data-projects-analytics-route="/en/projects/"
          class="mt-auto clip-corners hover-glitch inline-flex items-center justify-center min-h-11 text-center px-5 py-2 bg-cyan text-surface-dim font-bold text-xs uppercase tracking-wider"
        >
          {t('projects.card.casinocraftz.cta')}
        </a>
      </article>
    </div>
  </section>
</BaseLayout>

<script>
  import { ANALYTICS_EVENT_NAMES, emitAnalyticsEvent } from '../../../scripts/analytics/events';

  document.addEventListener('astro:page-load', () => {
    const controller = new AbortController();
    const { signal } = controller;

    const links = document.querySelectorAll<HTMLAnchorElement>('[data-projects-analytics-target]');
    for (const link of links) {
      link.addEventListener(
        'click',
        () => {
          emitAnalyticsEvent({
            name: ANALYTICS_EVENT_NAMES.PROJECTS_CTA_CLICK,
            route: link.dataset.projectsAnalyticsRoute ?? '/en/projects/',
            locale: link.dataset.projectsAnalyticsLocale === 'pt' ? 'pt' : 'en',
            surface: 'projects',
            payload: {
              target: link.dataset.projectsAnalyticsTarget ?? 'unknown',
            },
          });
        },
        { signal },
      );
    }

    document.addEventListener(
      'astro:before-swap',
      () => {
        controller.abort();
      },
      { once: true, signal },
    );
  });
</script>
