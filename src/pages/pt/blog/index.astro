---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('pt');
const allPosts = await getCollection('blog', ({ data }) => data.lang === 'pt');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Blog - Gabriel Rodrigues"
  description="Reflexoes sobre engenharia frontend, Vue, Angular, TypeScript, testes e performance web por Gabriel Rodrigues."
>
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-8">
    <h1
      class="text-4xl font-bold text-text-primary tracking-tight mb-2"
      style="letter-spacing: -0.03em;"
    >
      {t('blog.title')}
    </h1>
    <p class="text-text-muted font-mono text-sm mb-12">{t('blog.subtitle')}</p>
    {
      posts.length === 0 ? (
        <p class="text-text-muted font-mono text-sm">{t('blog.noPosts')}</p>
      ) : (
        <div class="grid gap-4">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id.replace('pt/', '')}
              tags={post.data.tags}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
