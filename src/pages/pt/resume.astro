---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperienceCard from '../../components/ExperienceCard.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('pt');
---

<BaseLayout
  title="Curriculo - Gabriel Rodrigues"
  description="Curriculo profissional de Gabriel Rodrigues — mais de 10 anos de experiencia em engenharia frontend em empresas como Betsson Group, Blexr e Capgemini."
>
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-8">
    <div class="flex items-center justify-between mb-10">
      <h1
        class="text-4xl font-bold text-text-primary tracking-tight"
        style="letter-spacing: -0.03em;"
      >
        {t('resume.title')}
      </h1>
      <a
        href="/resume.pdf"
        target="_blank"
        class="clip-corners hover-glitch px-5 py-2.5 bg-neon text-neon-on text-xs font-bold uppercase tracking-wider flex items-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path></svg
        >
        {t('resume.download')}
      </a>
    </div>

    <!-- Contact -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12 glow-panel p-5">
      <a
        href="mailto:help@gabriel-rodrigues.com"
        class="flex items-center gap-3 text-text-secondary hover:text-neon transition-colors group"
      >
        <span
          class="shrink-0 w-8 h-8 flex items-center justify-center bg-surface-container-low group-hover:bg-neon-dim transition-colors"
          style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.15);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
            ></path></svg
          >
        </span>
        <span class="font-mono text-xs tracking-wider">help@gabriel-rodrigues.com</span>
      </a>
      <a
        href="tel:+558199079346"
        class="flex items-center gap-3 text-text-secondary hover:text-neon transition-colors group"
      >
        <span
          class="shrink-0 w-8 h-8 flex items-center justify-center bg-surface-container-low group-hover:bg-neon-dim transition-colors"
          style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.15);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
            ></path></svg
          >
        </span>
        <span class="font-mono text-xs tracking-wider">+55 81 99079346</span>
      </a>
      <a
        href="https://www.linkedin.com/in/gabrielrodrigues-dev/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 text-text-secondary hover:text-neon transition-colors group"
      >
        <span
          class="shrink-0 w-8 h-8 flex items-center justify-center bg-surface-container-low group-hover:bg-neon-dim transition-colors"
          style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.15);"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
            ><path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path></svg
          >
        </span>
        <span class="font-mono text-xs tracking-wider">linkedin.com/in/gabrielrodrigues-dev</span>
      </a>
      <a
        href="https://github.com/softwareboutique42"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 text-text-secondary hover:text-neon transition-colors group"
      >
        <span
          class="shrink-0 w-8 h-8 flex items-center justify-center bg-surface-container-low group-hover:bg-neon-dim transition-colors"
          style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.15);"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
            ><path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path></svg
          >
        </span>
        <span class="font-mono text-xs tracking-wider">github.com/softwareboutique42</span>
      </a>
      <div class="flex items-center gap-3 text-text-secondary">
        <span
          class="shrink-0 w-8 h-8 flex items-center justify-center bg-surface-container-low"
          style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.15);"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
            ></path></svg
          >
        </span>
        <span class="font-mono text-xs tracking-wider">Brasil · Remoto</span>
      </div>
    </div>

    <!-- Summary -->
    <div class="mb-16 glow-panel p-6">
      <p class="text-text-secondary leading-relaxed">
        Engenheiro Frontend Senior com 10+ anos entregando aplicacoes web de alta escala em
        plataformas de iGaming, SaaS e fintech servindo milhoes de usuarios. Impacto comprovado:
        reducao de 60% em bugs via automacao E2E com Playwright, aumento de 22% em registros por
        redesign UX com testes A/B, e solucoes enterprise em Angular/Vue implantadas em 28+ marcas
        internacionais. Liderou equipes de ate 12 engenheiros, promoveu seguranca web (CSP,
        prevencao de XSS) e conduziu otimizacao de performance e acessibilidade (WCAG) em
        plataformas reguladas de alto trafego.
      </p>
    </div>

    <!-- Experience -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-8">
      {t('resume.experience')}
    </h2>
    <div class="mb-16">
      <ExperienceCard
        company="The Mill Adventure"
        role="Engenheiro Frontend Senior"
        period="Jul 2024 - Presente"
        location="Brasil · Remoto"
        achievements={[
          'Reduziu em 20% o tempo de resolucao do Suporte ao Cliente ao arquitetar fluxos KYC automatizados com BankID/Smart ID, eliminando verificacao manual.',
          'Reduziu bugs pos-lancamento em 60% ao construir suite E2E com Playwright cobrindo todos os caminhos criticos, integrada ao CI/CD para regressao automatizada.',
          'Eliminou superficie de vulnerabilidade XSS ao aplicar Content Security Policy (CSP) rigorosa e refatorar manipulacoes DOM inseguras para metodos sanitizados.',
          'Liderou redesign do backoffice em Angular 17 e Angular Material, reduzindo tempo medio de conclusao de tarefas em 35% para equipes de operacoes internas.',
          'Orientou 4 engenheiros backend em padroes TypeScript e arquitetura de componentes, reduzindo ciclos de revisao de PR em 40%.',
        ]}
      />
      <ExperienceCard
        company="Deskhero"
        role="Engenheiro Frontend Senior"
        period="Ago 2023 - Mai 2024"
        location="Torrevieja, Espanha"
        achievements={[
          'Arquitetou biblioteca Storybook com 52 componentes e regressao visual via Chromatic, reduzindo ciclos de desenvolvimento de features em 2 meses.',
          'Engenheirou pipeline de release automatizado com semantic-release e Commitizen, eliminando erros de versionamento manual em todos os deploys.',
          'Mentorou 3 engenheiros em Vue 3 Composition API, Pinia e testes unitarios com Jest, acelerando onboarding de 4 semanas para 2 semanas.',
        ]}
      />
      <ExperienceCard
        company="Betsson Group"
        role="Engenheiro Frontend Senior"
        period="Mar 2021 - Ago 2023"
        location="Malta"
        achievements={[
          'Entregou features de KYC, Onboarding e Compliance em Angular e Stencil.js implantadas em 28+ marcas de iGaming em mercados europeus regulados.',
          'Manteve 99.9% de uptime durante eventos de pico (Final da Copa do Mundo, 10x trafego normal) via gestao de incidentes on-call e deploy rapido de hotfixes.',
          'Liderou equipe de 10 engenheiros como Team Captain por 12 meses, aumentando velocidade de sprint em 25% via otimizacao de processos.',
          'Mentorou 5 desenvolvedores junior/pleno em TypeScript e GraphQL, reduzindo tempo medio de revisao de PR de 3 dias para 1 dia.',
        ]}
      />
      <ExperienceCard
        company="Ancient Gaming"
        role="Engenheiro Frontend Senior"
        period="Jul 2020 - Jan 2021"
        location="Malta"
        achievements={[
          'Engenheirou redesign do fluxo de registro em Angular, alcancando aumento de 22% em registros validado via testes A/B e Google Analytics.',
          'Redesenhou lobby e sistema de filtragem com componentes responsivos, gerando aumento de 14% em conversoes mobile de unboxing (validado via A/B).',
          'Integrou Zendesk e reformulou FAQ, reduzindo tempo medio de resposta do atendimento em 30%.',
        ]}
      />
      <ExperienceCard
        company="XCaliber"
        role="Engenheiro Frontend Senior"
        period="Set 2018 - Jul 2020"
        location="St Julians, Malta"
        achievements={[
          'Arquitetou aplicacoes web Angular para 4 marcas de iGaming (sunmaker.com, cherrycasino.com, manekichi.com, norgesspill.com) servindo milhoes de usuarios.',
          'Projetou arquitetura frontend multi-tenant com integracao RESTful, permitindo lancamento de novas marcas em 2 semanas versus 2 meses anteriormente.',
        ]}
      />
      <ExperienceCard
        company="Virtua Software"
        role="Engenheiro Full Stack"
        period="Fev 2014 - Jun 2018"
        location="Goiania, Brasil"
        achievements={[
          'Criou Virtua Web, plataforma self-service de negociacao de dividas servindo 500K+ usuarios — posteriormente adotada pelo Banco do Brasil e Caixa Economica Federal.',
          'Liderou equipe de 12 desenvolvedores, treinando estagiarios e estabelecendo padroes de codigo em projetos JavaScript, PHP e Bootstrap.',
        ]}
      />
    </div>

    <!-- Skills -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.skills')}
    </h2>
    <div class="mb-16 space-y-4">
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">Linguagens</p>
        <div class="flex flex-wrap gap-2">
          {
            ['TypeScript', 'JavaScript', 'HTML5', 'CSS3', 'SCSS', 'GraphQL'].map((skill) => (
              <span
                class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
              >
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">Frameworks</p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'Angular',
              'Vue 3',
              'Stencil.js',
              'Web Components',
              'Angular Material',
              'Tailwind CSS',
              'Node.js',
            ].map((skill) => (
              <span
                class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
              >
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">Testes</p>
        <div class="flex flex-wrap gap-2">
          {
            ['Playwright', 'Jest', 'Vitest', 'Storybook', 'Chromatic', 'A/B Testing'].map(
              (skill) => (
                <span
                  class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                  style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
                >
                  {skill}
                </span>
              ),
            )
          }
        </div>
      </div>
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">
          Ferramentas & Praticas
        </p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'Git',
              'CI/CD',
              'Docker',
              'Vite',
              'Pinia',
              'REST APIs',
              'Semantic Release',
              'Performance Optimization',
              'Accessibility (WCAG)',
              'Responsive Design',
              'Micro-frontends',
              'Design Systems',
            ].map((skill) => (
              <span
                class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
              >
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <div>
        <p class="font-mono text-xs text-text-muted mb-2 uppercase tracking-wider">Metodologias</p>
        <div class="flex flex-wrap gap-2">
          {
            ['Agile/Scrum', 'Code Review', 'Mentoria', 'Lideranca de Equipe'].map((skill) => (
              <span
                class="font-mono text-xs px-3 py-1.5 text-text-secondary bg-surface-container-low hover:text-neon hover:bg-neon-dim transition-colors uppercase tracking-wider"
                style="box-shadow: inset 0 0 0 0.5px rgba(142, 255, 113, 0.1);"
              >
                {skill}
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Education -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.education')}
    </h2>
    <div class="mb-16 glow-panel p-6">
      <h3 class="font-bold text-text-primary">Pontificia Universidade Catolica de Goias</h3>
      <p class="text-neon font-mono text-sm mt-1">
        Analise e Desenvolvimento de Sistemas, Engenharia de Software
      </p>
      <p class="text-xs text-text-muted font-mono mt-1 tracking-wider">2014 - 2018</p>
    </div>

    <!-- Languages -->
    <h2 class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">
      {t('resume.languages')}
    </h2>
    <div class="glow-panel p-6 flex gap-8">
      <div>
        <p class="text-text-primary font-medium">Ingles</p>
        <p class="text-xs text-text-muted font-mono mt-1">Profissional</p>
      </div>
      <div>
        <p class="text-text-primary font-medium">Portugues</p>
        <p class="text-xs text-text-muted font-mono mt-1">Nativo</p>
      </div>
    </div>
  </section>
</BaseLayout>
