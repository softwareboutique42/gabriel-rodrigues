---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('pt');
---

<BaseLayout
  title="Slots - Gabriel Rodrigues"
  description="Base shell de Slots com mensagem bilingue de desenvolvimento e aviso de conformidade."
>
  <section
    id="slots-shell-root"
    data-slots-shell="cabinet"
    data-slots-seed="slots-phase-13-pt"
    data-slots-theme="slots-core-v1"
    data-slots-motion="full"
    data-slots-host="standalone"
    data-slots-label-state={t('slots.gameplay.label.state')}
    data-slots-label-outcome={t('slots.gameplay.label.outcome')}
    data-slots-label-seed={t('slots.gameplay.label.seed')}
    data-slots-label-balance={t('slots.gameplay.label.balance')}
    data-slots-label-bet={t('slots.gameplay.label.bet')}
    data-slots-msg-idle={t('slots.gameplay.status.idle')}
    data-slots-msg-spinning={t('slots.gameplay.status.spinning')}
    data-slots-msg-result={t('slots.gameplay.status.result')}
    data-slots-msg-insufficient={t('slots.gameplay.status.insufficient')}
    data-slots-msg-blocked-spinning={t('slots.gameplay.status.blockedSpinning')}
    data-slots-msg-pending={t('slots.gameplay.status.pending')}
    class="slots-shell mx-auto max-w-6xl px-4 sm:px-6 pt-16 sm:pt-20 pb-12 sm:pb-16"
  >
    <div class="slots-shell__backdrop" aria-hidden="true">
      <div class="slots-shell__aura slots-shell__aura--neon"></div>
      <div class="slots-shell__aura slots-shell__aura--gold"></div>
      <div class="slots-shell__gridline"></div>
    </div>

    <header class="slots-shell__header" data-slots-zone="navigation">
      <a href="/" class="slots-shell__back-link" aria-label="Back to Casinocraftz">← CasinoCraftz</a>
      <div class="slots-shell__identity">
        <span class="slots-shell__identity-label">ELEMENTUM</span>
      </div>
    </header>

    <article class="slots-cabinet slots-cabinet--cyber glow-panel">
      <button
        type="button"
        class="slots-shell__menu-toggle"
        data-slots-menu-toggle
        aria-controls="slots-shell-menu"
        aria-expanded="false"
      >
        <span aria-hidden="true">+</span>
        <span class="sr-only">{t('slots.shell.label.theme')}</span>
      </button>

      <aside id="slots-shell-menu" class="slots-shell__menu-drawer" data-slots-menu aria-hidden="true">
        <p class="slots-shell__menu-title">Ajustes de Sinal</p>
        <div class="slots-shell__menu-row">
          <span>{t('slots.shell.label.routes')}</span>
          <strong data-slots-menu-routes>EN / PT</strong>
        </div>
        <div class="slots-shell__menu-row">
          <span>{t('slots.shell.label.motion')}</span>
          <strong data-slots-menu-motion>TOTAL</strong>
        </div>
        <div class="slots-shell__menu-row">
          <span>{t('slots.shell.label.theme')}</span>
          <strong data-slots-menu-theme>CORE V1</strong>
        </div>
      </aside>

      <section id="slots-gameplay" class="slots-stage slots-stage--immersive anim-tile-1" data-slots-zone="playfield">
        <div class="slots-stage__frame" data-slots-reel-frame>
          <div class="slots-stage__reel-window" data-slots-reel-window aria-hidden="true">
            <span class="slots-symbol">BAR</span>
          </div>
          <div class="slots-stage__reel-window" data-slots-reel-window aria-hidden="true">
            <span class="slots-symbol">7</span>
          </div>
          <div class="slots-stage__reel-window" data-slots-reel-window aria-hidden="true">
            <span class="slots-symbol">CROWN</span>
          </div>
        </div>

        <div class="slots-stage__hud slots-stage__hud--minimal">
          <div class="slots-meter" data-slots-meter="balance">
            <span class="slots-meter__label">{t('slots.gameplay.label.balance')}</span>
            <strong id="slots-balance-value" class="slots-meter__value slots-meter__value--neon">40</strong>
          </div>

          <div class="slots-meter" data-slots-meter="bet">
            <span class="slots-meter__label">{t('slots.gameplay.label.bet')}</span>
            <div class="slots-meter__controls">
              <button id="slots-bet-dec" type="button" class="slots-adjuster" aria-label="Diminuir aposta">-</button>
              <strong id="slots-bet-value" class="slots-meter__value slots-meter__value--cyan">2</strong>
              <button id="slots-bet-inc" type="button" class="slots-adjuster" aria-label="Aumentar aposta">+</button>
            </div>
          </div>

          <button
            id="slots-spin-button"
            data-slots-action="spin"
            type="button"
            class="slots-spin-button slots-spin-button--trigger"
          >
            {t('slots.gameplay.cta.spin')}
          </button>
        </div>

        <p id="slots-gameplay-status" class="sr-only" aria-live="polite"></p>
        <p id="slots-gameplay-outcome" class="sr-only"></p>
        <p id="slots-gameplay-seed" class="sr-only"></p>
      </section>
    </article>
  </section>

  <script>
    import { initSlotsShell } from '../../../scripts/slots/main';

    document.addEventListener('astro:page-load', () => {
      if (document.getElementById('slots-shell-root')) {
        initSlotsShell();
      }
    });
  </script>
</BaseLayout>
