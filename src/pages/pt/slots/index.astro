---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('pt');
---

<BaseLayout
  title="Slots - Gabriel Rodrigues"
  description="Base shell de Slots com mensagem bilingue de desenvolvimento e aviso de conformidade."
>
  <section
    id="slots-shell-root"
    data-slots-shell="cabinet"
    data-slots-seed="slots-phase-13-pt"
    data-slots-theme="slots-core-v1"
    data-slots-motion="full"
    data-slots-host="standalone"
    data-slots-label-state={t('slots.gameplay.label.state')}
    data-slots-label-outcome={t('slots.gameplay.label.outcome')}
    data-slots-label-seed={t('slots.gameplay.label.seed')}
    data-slots-label-balance={t('slots.gameplay.label.balance')}
    data-slots-label-bet={t('slots.gameplay.label.bet')}
    data-slots-msg-idle={t('slots.gameplay.status.idle')}
    data-slots-msg-spinning={t('slots.gameplay.status.spinning')}
    data-slots-msg-result={t('slots.gameplay.status.result')}
    data-slots-msg-insufficient={t('slots.gameplay.status.insufficient')}
    data-slots-msg-blocked-spinning={t('slots.gameplay.status.blockedSpinning')}
    data-slots-msg-pending={t('slots.gameplay.status.pending')}
    data-slots-odds-title={t('slots.odds.title')}
    data-slots-odds-copy={t('slots.odds.copy')}
    data-slots-odds-column-symbol={t('slots.odds.column.symbol')}
    data-slots-odds-column-chance={t('slots.odds.column.chance')}
    data-slots-odds-column-multiplier={t('slots.odds.column.multiplier')}
    data-slots-odds-column-payout={t('slots.odds.column.payout')}
    data-casinocraftz-current-lesson="house-edge"
    data-casinocraftz-tutorial-step="welcome"
    data-casinocraftz-essence="0"
    data-casinocraftz-essence-label={t('tutorial.essence.label')}
    data-casinocraftz-lesson-status-active={t('tutorial.lesson.status.active')}
    data-casinocraftz-lesson-status-complete={t('tutorial.lesson.status.complete')}
    data-casinocraftz-lesson-status-locked={t('tutorial.lesson.status.locked')}
    data-casinocraftz-lesson-open-label={t('tutorial.lesson.cta.open')}
    data-casinocraftz-lesson-review-label={t('tutorial.lesson.cta.review')}
    data-casinocraftz-lesson-preview-label={t('tutorial.lesson.cta.preview')}
    data-casinocraftz-lesson-house-edge-label={t('tutorial.lesson.houseEdge.label')}
    data-casinocraftz-lesson-house-edge-description={t('tutorial.lesson.houseEdge.description')}
    data-casinocraftz-lesson-near-miss-label={t('tutorial.lesson.nearMiss.label')}
    data-casinocraftz-lesson-near-miss-description={t('tutorial.lesson.nearMiss.description')}
    data-casinocraftz-lesson-sensory-conditioning-soon={t('tutorial.lesson.sensoryConditioning.soon')}
    data-casinocraftz-curriculum-progress-title={t('tutorial.curriculum.progressTitle')}
    data-casinocraftz-curriculum-bounded-rule={t('tutorial.curriculum.boundedRule')}
    data-casinocraftz-lesson-sensory-conditioning-label={t('tutorial.lesson.sensoryConditioning.label')}
    data-casinocraftz-lesson-sensory-conditioning-description={t(
      'tutorial.lesson.sensoryConditioning.description',
    )}
    data-casinocraftz-cards-title="Cartas Utilitarias"
    data-casinocraftz-activate-label={t('tutorial.cta.activateCard')}
    data-casinocraftz-replay-label={t('tutorial.cta.revisitLesson')}
    data-casinocraftz-recap-label={t('tutorial.cta.whyTransition')}
    data-casinocraftz-causality-probability-reveal={t('tutorial.causality.probabilityReveal')}
    data-casinocraftz-causality-near-miss-reveal={t('tutorial.causality.nearMissReveal')}
    data-casinocraftz-causality-sensory-reveal={t('tutorial.causality.sensoryReveal')}
    data-casinocraftz-step-welcome-label={t('tutorial.step.welcome.label')}
    data-casinocraftz-step-house-edge-intro-label={t('tutorial.step.houseEdgeIntro.label')}
    data-casinocraftz-step-play-and-observe-label={t('tutorial.step.playAndObserve.label')}
    data-casinocraftz-step-probability-reveal-label={t('tutorial.step.probabilityReveal.label')}
    data-casinocraftz-step-card-unlock-label={t('tutorial.step.cardUnlock.label')}
    data-casinocraftz-step-complete-label={t('tutorial.step.complete.label')}
    data-casinocraftz-step-near-miss-intro-label={t('tutorial.step.nearMissIntro.label')}
    data-casinocraftz-step-near-miss-observe-label={t('tutorial.step.nearMissObserve.label')}
    data-casinocraftz-step-near-miss-reveal-label={t('tutorial.step.nearMissReveal.label')}
    data-casinocraftz-step-near-miss-complete-label={t('tutorial.step.nearMissComplete.label')}
    data-casinocraftz-step-sensory-conditioning-intro-label={t('tutorial.step.sensoryConditioningIntro.label')}
    data-casinocraftz-step-sensory-conditioning-observe-label={t(
      'tutorial.step.sensoryConditioningObserve.label',
    )}
    data-casinocraftz-step-sensory-conditioning-reveal-label={t(
      'tutorial.step.sensoryConditioningReveal.label',
    )}
    data-casinocraftz-step-sensory-conditioning-complete-label={t(
      'tutorial.step.sensoryConditioningComplete.label',
    )}
    data-casinocraftz-card-status-locked={t('cards.status.locked')}
    data-casinocraftz-card-status-unlocked={t('cards.status.unlocked')}
    data-casinocraftz-card-probability-seer-label={t('cards.probabilitySeer.label')}
    data-casinocraftz-card-probability-seer-description={t('cards.probabilitySeer.description')}
    data-casinocraftz-card-dopamine-dampener-label={t('cards.dopamineDampener.label')}
    data-casinocraftz-card-dopamine-dampener-description={t('cards.dopamineDampener.description')}
    data-casinocraftz-card-house-edge-label={t('cards.houseEdge.label')}
    data-casinocraftz-card-house-edge-description={t('cards.houseEdge.description')}
    class="slots-shell mx-auto max-w-6xl px-4 sm:px-6 pt-16 sm:pt-20 pb-12 sm:pb-16"
  >
    <div class="slots-shell__backdrop" aria-hidden="true">
      <div class="slots-shell__aura slots-shell__aura--neon"></div>
      <div class="slots-shell__aura slots-shell__aura--gold"></div>
    </div>

    <header class="slots-shell__header" data-slots-zone="navigation">
      <a href="/pt/casinocraftz/" class="slots-shell__back-link" aria-label="Back to Casinocraftz"
        >← CasinoCraftz</a
      >
      <div class="slots-shell__identity">
        <span class="slots-shell__identity-label">ELEMENTUM</span>
      </div>
      <span id="slots-shell-status" class="sr-only">booting</span>
    </header>

    <article class="slots-cabinet slots-cabinet--cyber glow-panel">
      <button
        type="button"
        class="slots-shell__menu-toggle"
        data-slots-menu-toggle
        aria-controls="slots-shell-menu"
        aria-expanded="false"
      >
        <span data-slots-menu-icon aria-hidden="true">+</span>
        <span class="sr-only">Abrir painel lateral</span>
      </button>

      <div class="slots-shell__menu-backdrop" data-slots-menu-backdrop aria-hidden="true"></div>

      <aside
        id="slots-shell-menu"
        class="slots-shell__menu-drawer"
        data-slots-menu
        aria-hidden="true"
        role="dialog"
        aria-modal="true"
        tabindex="-1"
      >
        <div class="slots-shell__drawer-scroll">
          <section class="slots-shell__drawer-section" aria-label="Painel Analisador">
            <p class="slots-shell__menu-title">Painel Analisador</p>
            <p class="slots-shell__drawer-copy">Cartas utilitarias e ferramentas de leitura.</p>
            <div class="slots-shell__drawer-zone" data-slots-odds-panel></div>
            <div class="slots-shell__drawer-zone" data-casinocraftz-zone="cards"></div>
          </section>

          <section
            class="slots-shell__drawer-section"
            data-casinocraftz-zone="tutorial"
            aria-label="Registro de Missao"
          >
            <p class="slots-shell__menu-title">Registro de Missao</p>
            <p class="slots-shell__drawer-copy" data-casinocraftz-step-label></p>
            <p class="slots-shell__drawer-copy text-cyan" data-casinocraftz-essence-display></p>
            <div class="slots-shell__drawer-zone" data-casinocraftz-curriculum-progress></div>
            <div class="slots-shell__drawer-zone" data-casinocraftz-curriculum></div>
            <div class="slots-shell__drawer-zone" data-casinocraftz-dialogue></div>
            <div class="slots-shell__drawer-actions">
              <button type="button" class="slots-shell__drawer-btn" data-casinocraftz-tutorial-next>
                Proximo Passo
              </button>
              <button type="button" class="slots-shell__drawer-btn" data-casinocraftz-tutorial-skip>
                Pular Licao
              </button>
            </div>
          </section>

          <section class="slots-shell__drawer-section" aria-label="Ajustes">
            <p class="slots-shell__menu-title">Ajustes</p>
            <div class="slots-shell__menu-row">
              <span>{t('slots.shell.label.routes')}</span>
              <strong data-slots-menu-routes>EN / PT</strong>
            </div>
            <div class="slots-shell__menu-row">
              <span>{t('slots.shell.label.motion')}</span>
              <strong data-slots-menu-motion>TOTAL</strong>
            </div>
            <div class="slots-shell__menu-row">
              <span>{t('slots.shell.label.theme')}</span>
              <strong data-slots-menu-theme>CORE V1</strong>
            </div>
          </section>
        </div>
      </aside>

      <section
        id="slots-gameplay"
        class="slots-stage slots-stage--immersive anim-tile-1"
        data-slots-zone="playfield"
      >
        <div class="slots-stage__frame" data-slots-reel-frame>
          <div class="slots-stage__reel-window" data-slots-reel-window aria-hidden="true">
            <span class="slots-symbol">BAR</span>
          </div>
          <div class="slots-stage__reel-window" data-slots-reel-window aria-hidden="true">
            <span class="slots-symbol">7</span>
          </div>
          <div class="slots-stage__reel-window" data-slots-reel-window aria-hidden="true">
            <span class="slots-symbol">CROWN</span>
          </div>
        </div>

        <div class="slots-stage__hud slots-stage__hud--minimal">
          <div class="slots-meter" data-slots-meter="balance">
            <span class="slots-meter__label">{t('slots.gameplay.label.balance')}</span>
            <strong id="slots-balance-value" class="slots-meter__value slots-meter__value--neon"
              >40</strong
            >
          </div>

          <div class="slots-meter" data-slots-meter="bet">
            <span class="slots-meter__label">{t('slots.gameplay.label.bet')}</span>
            <div class="slots-meter__controls">
              <button
                id="slots-bet-dec"
                type="button"
                class="slots-adjuster"
                aria-label="Diminuir aposta">-</button
              >
              <strong id="slots-bet-value" class="slots-meter__value slots-meter__value--cyan"
                >2</strong
              >
              <button
                id="slots-bet-inc"
                type="button"
                class="slots-adjuster"
                aria-label="Aumentar aposta">+</button
              >
            </div>
          </div>

          <button
            id="slots-spin-button"
            data-slots-action="spin"
            type="button"
            class="slots-spin-button slots-spin-button--trigger"
          >
            {t('slots.gameplay.cta.spin')}
          </button>
        </div>

        <p id="slots-gameplay-status" class="sr-only" aria-live="polite"></p>
        <p id="slots-gameplay-outcome" class="sr-only"></p>
        <p id="slots-gameplay-seed" class="sr-only"></p>
        <aside
          class="mt-5 hud-outline-subtle p-4 text-left"
          data-slots-lesson="house-edge"
          aria-live="polite"
        >
          <p class="font-mono text-[10px] uppercase tracking-widest text-gold mb-2">
            {t('slots.education.houseEdgeLabel')}
          </p>
          <p class="text-sm text-text-secondary">{t('slots.education.houseEdgeCopy')}</p>
          <p class="mt-2 text-xs text-text-muted">{t('slots.education.manipulationCue')}</p>
        </aside>
        <pre id="slots-round-result" class="sr-only" aria-hidden="true"></pre>
      </section>
    </article>
  </section>

  <script>
    import { initSlotsShell } from '../../../scripts/slots/main';

    document.addEventListener('astro:page-load', () => {
      if (document.getElementById('slots-shell-root')) {
        initSlotsShell();
      }
    });
  </script>
</BaseLayout>
