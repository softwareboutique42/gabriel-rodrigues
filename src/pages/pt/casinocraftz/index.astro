---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('pt');
---

<BaseLayout
  title="Casinocraftz - Gabriel Rodrigues"
  description="Simulacao educacional transparente no navegador com estrutura sem risco e entrada para o modulo Slots."
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 sm:pt-20 pb-12 sm:pb-16">
    <article
      class="glow-panel p-6 sm:p-8"
      data-casinocraftz-shell-root
      data-casinocraftz-lang="pt"
      data-casinocraftz-tutorial-step="welcome"
      data-casinocraftz-essence="0"
      data-casinocraftz-essence-label={t('tutorial.essence.label')}
      data-casinocraftz-cards-title="Utility Cards"
      data-casinocraftz-activate-label={t('tutorial.cta.activateCard')}
      data-casinocraftz-replay-label={t('tutorial.cta.revisitLesson')}
      data-casinocraftz-recap-label={t('tutorial.cta.whyTransition')}
      data-casinocraftz-causality-probability-reveal={t('tutorial.causality.probabilityReveal')}
      data-casinocraftz-card-status-locked={t('cards.status.locked')}
      data-casinocraftz-card-status-unlocked={t('cards.status.unlocked')}
      data-casinocraftz-card-probability-seer-label={t('cards.probabilitySeer.label')}
      data-casinocraftz-card-probability-seer-description={t('cards.probabilitySeer.description')}
      data-casinocraftz-card-dopamine-dampener-label={t('cards.dopamineDampener.label')}
      data-casinocraftz-card-dopamine-dampener-description={t('cards.dopamineDampener.description')}
      data-casinocraftz-card-house-edge-label={t('cards.houseEdge.label')}
      data-casinocraftz-card-house-edge-description={t('cards.houseEdge.description')}
    >
      <header class="mb-8 sm:mb-10" data-casinocraftz-zone="foundation">
        <p class="font-mono text-xs text-cyan uppercase tracking-widest mb-3">
          {t('casinocraftz.badge.liveLab')}
        </p>
        <h1 class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-3 ls-tight-3">
          {t('casinocraftz.title')}
        </h1>
        <p class="text-text-muted font-mono text-xs sm:text-sm mb-4">
          {t('casinocraftz.subtitle')}
        </p>
        <p class="text-sm text-text-secondary max-w-2xl">{t('casinocraftz.disclaimer.zeroRisk')}</p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 mb-8 sm:mb-10">
        <section class="hud-outline-subtle p-4 sm:p-5" data-casinocraftz-zone="foundation">
          <p class="font-mono text-xs text-neon uppercase tracking-wider mb-2">
            {t('casinocraftz.zone.foundation')}
          </p>
          <p class="text-sm text-text-secondary">
            Paridade de rotas e estabilidade do shell principal agora estao garantidas.
          </p>
        </section>
        <section class="hud-outline-subtle p-4 sm:p-5" data-casinocraftz-zone="modules">
          <p class="font-mono text-xs text-cyan uppercase tracking-wider mb-2">
            {t('casinocraftz.zone.modules')}
          </p>
          <p class="text-sm text-text-secondary">
            Slots entra como modulo inicial enquanto utilitarios evoluem em paralelo.
          </p>
        </section>
        <section class="hud-outline-subtle p-4 sm:p-5" data-casinocraftz-zone="transparency">
          <p class="font-mono text-xs text-gold uppercase tracking-wider mb-2">
            {t('casinocraftz.zone.transparency')}
          </p>
          <p class="text-sm text-text-secondary">
            House edge e resultados permanecem explicaveis e nunca ligados a aposta real.
          </p>
        </section>
      </div>

      <section class="mb-8 sm:mb-10" data-casinocraftz-zone="modules">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
          <h2 class="text-xl sm:text-2xl font-bold text-text-primary tracking-tight">
            {t('slots.title')}
          </h2>
          <p class="font-mono text-xs text-cyan uppercase tracking-wider">
            Modulo 01: Runtime Embutido
          </p>
        </div>
        <p class="text-sm text-text-secondary mb-4">
          Modulo vivo com hooks deterministas de gameplay e camadas explicitas de transparencia.
        </p>
        <div class="hud-outline-subtle p-2 sm:p-3">
          <iframe
            data-casinocraftz-slots-embed
            src="/pt/slots/?host=casinocraftz"
            title="Modulo Slots do Casinocraftz"
            loading="lazy"
            class="w-full min-h-[980px] md:min-h-[860px] border border-surface-container-high"
          ></iframe>
        </div>
      </section>

      <section class="mt-6 sm:mt-8 hud-outline-subtle p-4 sm:p-6" data-casinocraftz-zone="tutorial">
        <header class="mb-4">
          <p class="font-mono text-xs text-cyan uppercase tracking-widest mb-1">
            {t('tutorial.step.welcome.label')}
          </p>
          <p
            class="font-mono text-xs text-neon uppercase tracking-wider"
            data-casinocraftz-essence-display
          >
            {t('tutorial.essence.label')}: 0
          </p>
        </header>
        <div data-casinocraftz-dialogue class="space-y-3 mb-4"></div>
        <button
          data-casinocraftz-tutorial-next
          class="clip-corners hover-glitch inline-flex items-center justify-center min-h-9 px-4 py-1.5 bg-cyan text-bg font-bold text-xs uppercase tracking-wider"
        >
          {t('tutorial.cta.nextStep')}
        </button>
        <button
          data-casinocraftz-tutorial-skip
          class="ml-3 inline-flex items-center justify-center min-h-9 px-4 py-1.5 text-text-muted font-mono text-xs hover:text-neon transition-colors"
        >
          {t('tutorial.cta.skipTutorial')}
        </button>
      </section>

      <section class="mt-4 sm:mt-6" data-casinocraftz-zone="cards">
        <p class="font-mono text-xs text-gold uppercase tracking-wider mb-3">Utility Cards</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div data-casinocraftz-card="probability-seer" class="hud-outline-subtle p-3">
            <p class="font-mono text-xs text-neon uppercase tracking-wider mb-1">
              {t('cards.probabilitySeer.label')}
            </p>
            <p class="text-xs text-text-muted mb-2">{t('cards.probabilitySeer.description')}</p>
            <button
              data-casinocraftz-card-activate="probability-seer"
              aria-disabled="true"
              class="font-mono text-xs text-text-muted uppercase tracking-wider"
            >
              {t('tutorial.cta.activateCard')}
            </button>
          </div>
          <div data-casinocraftz-card="dopamine-dampener" class="hud-outline-subtle p-3">
            <p class="font-mono text-xs text-neon uppercase tracking-wider mb-1">
              {t('cards.dopamineDampener.label')}
            </p>
            <p class="text-xs text-text-muted mb-2">{t('cards.dopamineDampener.description')}</p>
            <button
              data-casinocraftz-card-activate="dopamine-dampener"
              aria-disabled="true"
              class="font-mono text-xs text-text-muted uppercase tracking-wider"
            >
              {t('tutorial.cta.activateCard')}
            </button>
          </div>
          <div data-casinocraftz-card="house-edge" class="hud-outline-subtle p-3">
            <p class="font-mono text-xs text-neon uppercase tracking-wider mb-1">
              {t('cards.houseEdge.label')}
            </p>
            <p class="text-xs text-text-muted mb-2">{t('cards.houseEdge.description')}</p>
            <button
              data-casinocraftz-card-activate="house-edge"
              aria-disabled="true"
              class="font-mono text-xs text-text-muted uppercase tracking-wider"
            >
              {t('tutorial.cta.activateCard')}
            </button>
          </div>
        </div>
      </section>

      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
        <a
          href="/pt/slots/"
          class="clip-corners hover-glitch inline-flex items-center justify-center min-h-11 px-5 py-2 bg-neon text-neon-on font-bold text-xs uppercase tracking-wider"
        >
          {t('casinocraftz.cta.openSlots')}
        </a>
        <a
          href="/pt/projects/"
          class="inline-flex items-center justify-center min-h-11 px-5 py-2 border border-surface-container-high text-text-primary font-bold text-xs uppercase tracking-wider hover:text-neon transition-colors"
        >
          {t('casinocraftz.cta.backProjects')}
        </a>
      </div>
    </article>
  </section>

  <script>
    import { mountTutorial } from '../../../scripts/casinocraftz/tutorial/main';

    document.addEventListener('astro:page-load', () => {
      const root = document.querySelector('[data-casinocraftz-shell-root]') as HTMLElement | null;
      if (!root) return;
      const lang = (root.dataset.casinocraftzLang ?? 'en') as 'en' | 'pt';
      mountTutorial({ lang });
    });
  </script>
</BaseLayout>
