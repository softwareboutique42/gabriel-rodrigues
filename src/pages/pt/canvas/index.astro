---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('pt');
---

<BaseLayout
  title="Company Canvas - Gabriel Rodrigues"
  description="Gerador de identidade visual com IA e animacoes Three.js ao vivo. Digite o nome de uma empresa e veja ganhar vida."
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 sm:pt-20 pb-8">
    <h1
      class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-1 sm:mb-2 ls-tight-3"
    >
      {t('canvas.title')}
    </h1>
    <p class="text-text-muted font-mono text-xs sm:text-sm mb-6 sm:mb-12">
      {t('canvas.subtitle')}
    </p>

    <!-- Input Panel -->
    <div class="glow-panel p-4 sm:p-6 mb-6 sm:mb-8">
      <form id="canvas-form" class="flex flex-col sm:flex-row gap-3 sm:gap-4 items-end">
        <div class="flex-1 w-full">
          <label
            for="canvas-input"
            class="block font-mono text-xs text-text-muted uppercase tracking-widest mb-2"
          >
            {t('canvas.input.label')}
          </label>
          <input
            type="text"
            id="canvas-input"
            maxlength="100"
            placeholder={t('canvas.input.placeholder')}
            class="w-full min-h-11 bg-transparent text-text-primary font-mono text-sm py-2 neon-underline"
            required
          />
        </div>
        <div class="flex w-full sm:w-auto gap-3 items-end">
          <div class="shrink-0">
            <label
              for="version-select"
              class="block font-mono text-xs text-text-muted uppercase tracking-widest mb-2"
            >
              {t('canvas.version.label')}
            </label>
            <select
              id="version-select"
              class="min-h-11 bg-surface-container text-text-primary font-mono text-sm py-2 px-3 border border-surface-container-high cursor-pointer"
            >
            </select>
          </div>
          <div class="shrink-0">
            <label
              for="preset-select"
              class="block font-mono text-xs text-text-muted uppercase tracking-widest mb-2"
            >
              {t('canvas.preset.label')}
            </label>
            <select
              id="preset-select"
              data-auto-label={t('canvas.preset.auto')}
              data-label-education-story={t('canvas.preset.educationStory')}
              data-label-hospitality-orbit={t('canvas.preset.hospitalityOrbit')}
              data-label-commerce-signal={t('canvas.preset.commerceSignal')}
              class="min-h-11 bg-surface-container text-text-primary font-mono text-sm py-2 px-3 border border-surface-container-high cursor-pointer"
            >
            </select>
          </div>
          <button
            type="submit"
            class="clip-corners hover-glitch flex-1 sm:flex-none min-h-11 px-6 sm:px-8 py-3 bg-neon text-neon-on font-bold text-sm uppercase tracking-wider"
          >
            {t('canvas.generate')}
          </button>
        </div>
      </form>
    </div>

    <!-- Canvas Viewport -->
    <div class="glow-panel relative mb-8 canvas-viewport">
      <!-- Idle state -->
      <div id="canvas-idle" class="absolute inset-0 flex items-center justify-center">
        <p class="font-mono text-sm text-text-muted uppercase tracking-widest">
          <span class="text-neon">&gt;</span> aguardando entrada_
        </p>
      </div>

      <!-- Loading state -->
      <div id="canvas-loading" class="absolute inset-0 flex items-center justify-center hidden">
        <div class="text-center">
          <p class="font-mono text-sm text-neon uppercase tracking-widest animate-pulse">
            {t('canvas.loading')}
          </p>
          <div class="mt-4 h-0.5 w-48 mx-auto bg-surface-container-high overflow-hidden">
            <div class="h-full bg-neon animate-[loading_2s_ease-in-out_infinite] hud-progress-30">
            </div>
          </div>
        </div>
      </div>

      <!-- Error state -->
      <div id="canvas-error" class="absolute inset-0 flex items-center justify-center hidden">
        <div class="text-center">
          <p class="font-mono text-sm text-gold uppercase tracking-widest mb-4">
            {t('canvas.error')}
          </p>
          <button
            id="error-retry"
            class="inline-flex items-center min-h-11 px-2 font-mono text-xs text-neon uppercase tracking-widest hover:text-gold transition-colors"
          >
            {t('canvas.retry')}
          </button>
        </div>
      </div>

      <!-- Result: Canvas + Overlay -->
      <div id="canvas-result" class="absolute inset-0 hidden">
        <canvas id="canvas-el" class="w-full h-full" aria-label="Animacao de marca da empresa"
        ></canvas>
        <div class="absolute bottom-4 left-4 sm:bottom-6 sm:left-6 z-10 pointer-events-none">
          <p
            id="overlay-name"
            class="text-3xl sm:text-4xl font-bold tracking-tight ls-tight-3 hud-overlay-title"
          >
          </p>
          <p id="overlay-tagline" class="font-mono text-sm mt-1 hud-overlay-subtitle"></p>
        </div>
        <div
          class="absolute top-3 right-3 sm:top-4 sm:right-4 z-10 flex items-center gap-2 sm:gap-3"
        >
          <button
            id="canvas-download"
            class="inline-flex items-center justify-center min-h-11 font-mono text-xs text-neon hover:text-gold transition-colors uppercase tracking-widest hud-chip"
          >
            {t('canvas.download')}
          </button>
          <button
            id="canvas-share"
            class="inline-flex items-center justify-center min-h-11 font-mono text-xs text-text-muted hover:text-neon transition-colors uppercase tracking-widest hud-chip"
          >
            {t('canvas.share')}
          </button>
          <button
            id="canvas-retry"
            class="inline-flex items-center justify-center min-h-11 font-mono text-xs text-text-muted hover:text-neon transition-colors uppercase tracking-widest hud-chip"
          >
            {t('canvas.retry')}
          </button>
        </div>
      </div>
    </div>

    <!-- Info Panel -->
    <div id="canvas-info" class="glow-panel p-4 sm:p-6 hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
        <div>
          <p class="font-mono text-xs text-text-muted uppercase tracking-widest mb-2">
            {t('canvas.info.industry')}
          </p>
          <p id="info-industry" class="text-text-primary text-sm font-mono"></p>
        </div>
        <div>
          <p class="font-mono text-xs text-text-muted uppercase tracking-widest mb-2">
            {t('canvas.info.description')}
          </p>
          <p id="info-description" class="text-text-secondary text-sm"></p>
        </div>
        <div>
          <p class="font-mono text-xs text-text-muted uppercase tracking-widest mb-2">
            {t('canvas.info.style')}
          </p>
          <p id="info-style" class="text-neon text-sm font-mono uppercase"></p>
        </div>
        <div>
          <p class="font-mono text-xs text-text-muted uppercase tracking-widest mb-2">
            {t('canvas.info.colors')}
          </p>
          <div id="info-palette" class="space-y-1"></div>
        </div>
      </div>
    </div>

    <!-- Download Processing State -->
    <div
      id="canvas-download-processing"
      class="glow-panel p-6 mt-8 hidden"
      data-processing-text={t('canvas.download.processing')}
      data-preparing-text={t('canvas.download.preparing')}
      data-exporting-text={t('canvas.download.exporting')}
      data-complete-text={t('canvas.download.complete')}
      data-fallback-text={t('canvas.download.fallback')}
      data-unsupported-text={t('canvas.download.unsupported')}
      data-error-text={t('canvas.download.error')}
      data-keep-active-text={t('canvas.download.keepActive')}
      data-progress-template-text={t('canvas.download.progressTemplate')}
      data-modal-format-hint-mp4-text={t('canvas.exportModal.hint.mp4')}
      data-modal-format-hint-webm-only-text={t('canvas.exportModal.hint.webmOnly')}
      data-modal-format-hint-unsupported-text={t('canvas.exportModal.hint.unsupported')}
      data-payment-confirmed-text={t('canvas.download.paymentConfirmed')}
    >
      <div class="text-center">
        <p
          id="download-status"
          class="font-mono text-sm text-neon uppercase tracking-widest animate-pulse"
        >
          {t('canvas.download.processing')}
        </p>
        <p
          id="download-warning"
          class="font-mono text-xs text-text-muted mt-3 uppercase tracking-wide"
        >
          {t('canvas.download.keepActive')}
        </p>
        <div class="mt-4 max-w-md mx-auto">
          <div class="h-1 w-full bg-surface-container-high overflow-hidden">
            <div id="download-progress-bar" class="h-full bg-neon hud-progress-0"></div>
          </div>
          <p id="download-progress-label" class="font-mono text-xs text-text-muted mt-2"></p>
        </div>
      </div>
    </div>

    <!-- Export Options Modal -->
    <div
      id="canvas-export-modal"
      class="fixed inset-0 z-40 hidden bg-surface-dim/80 backdrop-blur-[1px] px-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="export-modal-title"
      aria-describedby="export-format-hint"
      aria-hidden="true"
    >
      <div class="min-h-full flex items-center justify-center">
        <div class="glow-panel w-full max-w-xl p-5 sm:p-6">
          <h2
            id="export-modal-title"
            class="text-xl sm:text-2xl font-bold text-text-primary tracking-tight"
          >
            {t('canvas.exportModal.title')}
          </h2>
          <p class="font-mono text-xs text-text-muted uppercase tracking-wide mt-1 mb-5">
            {t('canvas.exportModal.subtitle')}
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <label class="block">
              <span class="block font-mono text-xs text-text-muted uppercase tracking-widest mb-2">
                {t('canvas.exportModal.format.label')}
              </span>
              <select
                id="export-format"
                class="w-full bg-surface-container text-text-primary font-mono text-sm py-2 px-3 border border-surface-container-high"
              >
                <option value="webm">{t('canvas.exportModal.format.webm')}</option>
                <option value="mp4">{t('canvas.exportModal.format.mp4')}</option>
              </select>
            </label>

            <label class="block">
              <span class="block font-mono text-xs text-text-muted uppercase tracking-widest mb-2">
                {t('canvas.exportModal.aspectRatio.label')}
              </span>
              <select
                id="export-aspect-ratio"
                class="w-full bg-surface-container text-text-primary font-mono text-sm py-2 px-3 border border-surface-container-high"
              >
                <option value="16:9">{t('canvas.exportModal.aspectRatio.wide')}</option>
                <option value="1:1">{t('canvas.exportModal.aspectRatio.square')}</option>
                <option value="9:16">{t('canvas.exportModal.aspectRatio.vertical')}</option>
              </select>
            </label>

            <label class="block">
              <span class="block font-mono text-xs text-text-muted uppercase tracking-widest mb-2">
                {t('canvas.exportModal.quality.label')}
              </span>
              <select
                id="export-quality"
                class="w-full bg-surface-container text-text-primary font-mono text-sm py-2 px-3 border border-surface-container-high"
              >
                <option value="1080p">{t('canvas.exportModal.quality.fullHd')}</option>
                <option value="720p">{t('canvas.exportModal.quality.hd')}</option>
              </select>
            </label>
          </div>

          <p id="export-format-hint" class="font-mono text-xs text-text-muted mt-4">
            {t('canvas.exportModal.hint.mp4')}
          </p>

          <p class="font-mono text-xs text-neon/80 mt-3 uppercase tracking-wide">
            {t('canvas.exportModal.valueProp')}
          </p>

          <div class="flex items-center justify-end gap-3 mt-6">
            <button
              id="export-modal-cancel"
              type="button"
              class="inline-flex items-center min-h-11 px-2 font-mono text-xs text-text-muted hover:text-neon transition-colors uppercase tracking-widest"
            >
              {t('canvas.exportModal.cancel')}
            </button>
            <button
              id="export-modal-confirm"
              type="button"
              class="clip-corners hover-glitch inline-flex items-center min-h-11 px-4 py-2 bg-neon text-neon-on font-bold text-xs uppercase tracking-wider"
            >
              {t('canvas.exportModal.continue')}
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Legal Disclaimer -->
    <div class="mt-8 px-2">
      <p class="font-mono text-xs text-text-muted leading-relaxed">
        {t('canvas.disclaimer')}
      </p>
    </div>
  </section>

  <script>
    import { initCanvas } from '../../../scripts/canvas/main';
    document.addEventListener('astro:page-load', () => {
      if (document.getElementById('canvas-form')) {
        initCanvas();
      }
    });
  </script>

  <style>
    @keyframes loading {
      0% {
        transform: translateX(-100%);
      }
      50% {
        transform: translateX(200%);
      }
      100% {
        transform: translateX(-100%);
      }
    }
  </style>
</BaseLayout>
