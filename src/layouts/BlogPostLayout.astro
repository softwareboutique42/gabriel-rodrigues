---
import BaseLayout from './BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';
import ShareBar from '../components/ShareBar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  headings?: Heading[];
  body?: string;
}

const { title, description, date, tags, headings = [], body = '' } = Astro.props;
const wordCount = body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
const lang = getLangFromUrl(Astro.url);
const slug = Astro.url.pathname.replace(`/${lang}/blog/`, '').replace(/\/$/, '');
const t = useTranslations(lang);

const formattedDate = date.toLocaleDateString(lang === 'pt' ? 'pt-BR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(`/og/${lang}/blog/${slug}.png`, Astro.site).href;

const blogJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Gabriel Rodrigues',
    url: 'https://gabriel-rodrigues.com',
  },
  keywords: tags.join(', '),
  inLanguage: lang === 'pt' ? 'pt-BR' : 'en',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(Astro.url.pathname, Astro.site).href,
  },
});
---

<BaseLayout
  title={`${title} - Gabriel Rodrigues`}
  description={description}
  ogImage={ogImageUrl}
  ogType="article"
  articleMeta={{ publishedTime: date.toISOString(), tags }}
>
  <script type="application/ld+json" set:html={blogJsonLd} />
  <article class="max-w-3xl mx-auto px-6 pt-20 pb-8">
    <a
      href={`/${lang}/blog/`}
      class="inline-flex items-center gap-1 font-mono text-xs text-text-muted hover:text-neon transition-colors mb-10 uppercase tracking-wider"
    >
      &larr; {t('blog.back')}
    </a>
    <header class="mb-12">
      <div class="flex items-center gap-3">
        <time class="font-mono text-xs text-text-muted tracking-wider uppercase"
          >{formattedDate}</time
        >
        <span class="font-mono text-xs text-text-muted">·</span>
        <span class="font-mono text-xs text-text-muted tracking-wider"
          >{readingTime} {t('blog.readTime')}</span
        >
      </div>
      <h1
        class="text-3xl sm:text-4xl font-bold text-text-primary mt-3 mb-4 tracking-tight"
        style="letter-spacing: -0.02em;"
        transition:name={`post-title-${slug}`}
      >
        {title}
      </h1>
      <p class="text-lg text-text-secondary">{description}</p>
      {
        tags.length > 0 && (
          <div class="flex gap-2 mt-4 flex-wrap">
            {tags.map((tag) => (
              <span class="font-mono text-xs px-2 py-0.5 text-cyan bg-cyan-dim uppercase tracking-wider">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>
    <TableOfContents headings={headings} />
    <div class="prose">
      <slot />
    </div>
    <ShareBar url={canonicalUrl} title={title} />
    <AdUnit format="auto" />
  </article>
</BaseLayout>
