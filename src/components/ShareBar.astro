---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const twitterUrl = `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
---

<div
  class="share-bar flex items-center gap-4 mt-12 mb-8 pt-8"
  style="box-shadow: inset 0 0.5px 0 rgba(142, 255, 113, 0.1);"
>
  <span class="font-mono text-xs text-text-muted tracking-widest uppercase">{t('blog.share')}</span>
  <div class="flex gap-3 flex-wrap">
    <a
      href={twitterUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="glow-panel hover-glitch flex items-center gap-2.5 px-3.5 py-2 font-mono text-xs text-text-secondary hover:text-neon transition-colors"
      aria-label="Share on X"
    >
      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"
        ><path
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
        ></path></svg
      >
      <span class="tracking-wider">X</span>
    </a>
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="glow-panel hover-glitch flex items-center gap-2.5 px-3.5 py-2 font-mono text-xs text-text-secondary hover:text-neon transition-colors"
      aria-label="Share on LinkedIn"
    >
      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"
        ><path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        ></path></svg
      >
      <span class="tracking-wider">LinkedIn</span>
    </a>
    <button
      id="copy-link-btn"
      class="glow-panel hover-glitch flex items-center gap-2.5 px-3.5 py-2 font-mono text-xs text-text-secondary hover:text-neon transition-colors cursor-pointer"
      style="border: none;"
      data-url={url}
      data-copied-text={t('blog.copied')}
      aria-label="Copy link"
    >
      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"
        ><path
          d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7a5 5 0 000 10h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4a5 5 0 000-10z"
        ></path></svg
      >
      <span class="copy-label tracking-wider">{t('blog.copyLink')}</span>
    </button>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('copy-link-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const url = btn.dataset.url || window.location.href;
      const copiedText = btn.dataset.copiedText || 'Copied!';
      const label = btn.querySelector('.copy-label');
      if (!label) return;
      const original = label.textContent;
      navigator.clipboard.writeText(url).then(() => {
        label.textContent = copiedText;
        setTimeout(() => {
          label.textContent = original;
        }, 2000);
      });
    });
  });
</script>
