---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const targetLang = lang === 'en' ? 'pt' : 'en';
const targetPath = getLocalizedPath(Astro.url.pathname, targetLang);
---

<a
  href={targetPath}
  class="inline-flex items-center justify-center min-h-11 px-3 sm:px-3.5 font-mono text-xs tracking-normal sm:tracking-widest text-cyan hover:text-gold transition-colors hover-glitch hud-outline-cyan"
>
  {t('lang.switch')}
</a>
