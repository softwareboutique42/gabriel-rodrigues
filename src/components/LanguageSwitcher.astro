---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const targetLang = lang === 'en' ? 'pt' : 'en';
const targetPath = getLocalizedPath(Astro.url.pathname, targetLang);
---

<a
  href={targetPath}
  class="font-mono text-xs tracking-normal sm:tracking-widest px-1.5 sm:px-2.5 py-1 text-cyan hover:text-gold transition-colors hover-glitch"
  style="box-shadow: inset 0 0 0 0.5px rgba(143, 245, 255, 0.2);"
>
  {t('lang.switch')}
</a>
