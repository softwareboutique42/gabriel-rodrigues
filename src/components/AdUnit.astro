---
interface Props {
  format?: 'auto' | 'horizontal' | 'rectangle' | 'vertical';
  layout?: string;
}

const { format = 'auto', layout } = Astro.props;
---

<div class="ad-container my-8 hud-outline-subtle">
  <p class="font-mono text-[10px] text-text-muted tracking-widest uppercase mb-2 opacity-50">
    Sponsored
  </p>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-9809167954901529"
    data-ad-format={format}
    {...layout ? { 'data-ad-layout': layout } : {}}
    data-full-width-responsive="true"></ins>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    if (typeof window === 'undefined') return;

    const initializeAds = () => {
      const ads = document.querySelectorAll('.adsbygoogle');
      ads.forEach((ad) => {
        if (!ad.getAttribute('data-adsbygoogle-status')) {
          try {
            const win = window as Window & { adsbygoogle?: Record<string, unknown>[] };
            (win.adsbygoogle = win.adsbygoogle || []).push({});
          } catch {
            // AdSense not loaded or blocked
          }
        }
      });
    };

    const existingScript = document.querySelector<HTMLScriptElement>(
      'script[data-adsense-loader="true"]',
    );

    if (existingScript) {
      if ((window as Window & { adsbygoogle?: Record<string, unknown>[] }).adsbygoogle) {
        initializeAds();
      } else {
        existingScript.addEventListener('load', initializeAds, { once: true });
      }
      return;
    }

    const script = document.createElement('script');
    script.async = true;
    script.crossOrigin = 'anonymous';
    script.dataset.adsenseLoader = 'true';
    script.src =
      'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9809167954901529';
    script.addEventListener('load', initializeAds, { once: true });
    document.head.appendChild(script);
  });
</script>
