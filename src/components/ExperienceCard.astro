---
interface Props {
  company: string;
  role: string;
  period: string;
  location: string;
  achievements: string[];
}

const { company, role, period, location, achievements } = Astro.props;
---

<div
  class="relative pl-8 pb-12 last:pb-0 group"
  style="border-left: 1px solid rgba(255, 124, 43, 0.1);"
>
  <div
    class="absolute left-0 top-1 w-2.5 h-2.5 -translate-x-[5.5px] bg-neon group-hover:shadow-[0_0_12px_rgba(142,255,113,0.4)] transition-shadow"
    style="clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);"
  >
  </div>
  <div class="mb-3">
    <h3 class="text-lg font-bold text-text-primary tracking-tight">{company}</h3>
    <p class="text-neon font-mono text-sm">{role}</p>
    <p class="text-xs text-text-muted font-mono tracking-wider mt-1 uppercase">
      {period}
      <span class="text-cyan">&middot;</span>
      {location}
    </p>
  </div>
  <ul class="space-y-2">
    {
      achievements.map((item) => (
        <li class="text-sm text-text-secondary flex gap-3">
          <span class="text-neon mt-0.5 shrink-0 font-mono text-xs">&gt;</span>
          <span>{item}</span>
        </li>
      ))
    }
  </ul>
</div>
