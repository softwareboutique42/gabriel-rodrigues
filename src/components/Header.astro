---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const isProjectsSurface =
  currentPath.includes('/projects') ||
  currentPath.includes('/canvas') ||
  currentPath.includes('/slots');
---

<header class="sticky top-0 z-50 bg-surface-dim/80 backdrop-blur-md hud-line-bottom">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between">
    <a
      href={`/${lang}/`}
      class="font-mono text-neon text-xs sm:text-sm tracking-wide sm:tracking-widest hover-glitch"
      transition:name="logo"
    >
      &gt; GR_
    </a>
    <div class="flex items-center gap-2 sm:gap-6">
      <a
        href={`/${lang}/`}
        class:list={[
          'inline-flex items-center min-h-11 px-1 text-xs font-mono uppercase tracking-normal sm:tracking-wider transition-colors',
          currentPath === `/${lang}/`
            ? 'nav-active text-neon'
            : 'text-text-secondary hover:text-neon',
        ]}
      >
        {t('nav.home')}
      </a>
      <a
        href={`/${lang}/resume/`}
        class:list={[
          'inline-flex items-center min-h-11 px-1 text-xs font-mono uppercase tracking-normal sm:tracking-wider transition-colors',
          currentPath.includes('/resume')
            ? 'nav-active text-neon'
            : 'text-text-secondary hover:text-neon',
        ]}
      >
        {t('nav.resume')}
      </a>
      <a
        href={`/${lang}/blog/`}
        class:list={[
          'inline-flex items-center min-h-11 px-1 text-xs font-mono uppercase tracking-normal sm:tracking-wider transition-colors',
          currentPath.includes('/blog')
            ? 'nav-active text-neon'
            : 'text-text-secondary hover:text-neon',
        ]}
      >
        {t('nav.blog')}
      </a>
      <a
        href={`/${lang}/projects/`}
        class:list={[
          'inline-flex items-center min-h-11 px-1 text-xs font-mono uppercase tracking-normal sm:tracking-wider transition-colors',
          isProjectsSurface ? 'nav-active text-neon' : 'text-text-secondary hover:text-neon',
        ]}
      >
        {t('nav.projects')}
      </a>
      <LanguageSwitcher />
    </div>
  </nav>
</header>
