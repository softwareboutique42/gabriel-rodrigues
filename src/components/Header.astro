---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const isProjectsSurface =
  currentPath.includes('/projects') ||
  currentPath.includes('/canvas') ||
  currentPath.includes('/slots');
---

<header class="sticky top-0 z-50 bg-surface-dim/80 backdrop-blur-md hud-line-bottom">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between">
    <a
      href={`/${lang}/`}
      class="font-mono text-neon text-xs sm:text-sm tracking-wide sm:tracking-widest hover-glitch"
      transition:name="logo"
    >
      &gt; GR_
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-6">
      <a
        href={`/${lang}/`}
        class:list={[
          'text-xs font-mono uppercase tracking-wider transition-colors',
          currentPath === `/${lang}/`
            ? 'nav-active text-neon'
            : 'text-text-secondary hover:text-neon',
        ]}
      >
        {t('nav.home')}
      </a>
      <a
        href={`/${lang}/resume/`}
        class:list={[
          'text-xs font-mono uppercase tracking-wider transition-colors',
          currentPath.includes('/resume')
            ? 'nav-active text-neon'
            : 'text-text-secondary hover:text-neon',
        ]}
      >
        {t('nav.resume')}
      </a>
      <a
        href={`/${lang}/blog/`}
        class:list={[
          'text-xs font-mono uppercase tracking-wider transition-colors',
          currentPath.includes('/blog')
            ? 'nav-active text-neon'
            : 'text-text-secondary hover:text-neon',
        ]}
      >
        {t('nav.blog')}
      </a>
      <a
        href={`/${lang}/projects/`}
        class:list={[
          'text-xs font-mono uppercase tracking-wider transition-colors',
          isProjectsSurface ? 'nav-active text-neon' : 'text-text-secondary hover:text-neon',
        ]}
      >
        {t('nav.projects')}
      </a>
      <LanguageSwitcher />
    </div>

    <!-- Mobile: lang switcher + hamburger -->
    <div class="flex sm:hidden items-center gap-2">
      <LanguageSwitcher />
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="min-h-11 min-w-11 flex items-center justify-center font-mono text-sm text-text-secondary hover:text-neon transition-colors"
      >
        <svg
          id="hamburger-icon"
          width="18"
          height="14"
          viewBox="0 0 18 14"
          fill="none"
          aria-hidden="true"
        >
          <rect width="18" height="1.5" y="0" fill="currentColor"></rect>
          <rect width="12" height="1.5" y="6" fill="currentColor"></rect>
          <rect width="18" height="1.5" y="12" fill="currentColor"></rect>
        </svg>
        <svg
          id="close-icon"
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
          class="hidden"
        >
          <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="1.5"></line>
          <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="1.5"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav drawer -->
  <div
    id="mobile-nav"
    class="hidden sm:hidden border-t hud-line-top bg-surface-dim/95 backdrop-blur-md"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-0.5">
      <a
        href={`/${lang}/`}
        class:list={[
          'flex items-center min-h-11 px-2 text-sm font-mono uppercase tracking-wider transition-colors',
          currentPath === `/${lang}/` ? 'text-neon' : 'text-text-secondary hover:text-neon',
        ]}
      >
        {currentPath === `/${lang}/` ? '> ' : ''}{t('nav.home')}
      </a>
      <a
        href={`/${lang}/resume/`}
        class:list={[
          'flex items-center min-h-11 px-2 text-sm font-mono uppercase tracking-wider transition-colors',
          currentPath.includes('/resume') ? 'text-neon' : 'text-text-secondary hover:text-neon',
        ]}
      >
        {currentPath.includes('/resume') ? '> ' : ''}{t('nav.resume')}
      </a>
      <a
        href={`/${lang}/blog/`}
        class:list={[
          'flex items-center min-h-11 px-2 text-sm font-mono uppercase tracking-wider transition-colors',
          currentPath.includes('/blog') ? 'text-neon' : 'text-text-secondary hover:text-neon',
        ]}
      >
        {currentPath.includes('/blog') ? '> ' : ''}{t('nav.blog')}
      </a>
      <a
        href={`/${lang}/projects/`}
        class:list={[
          'flex items-center min-h-11 px-2 text-sm font-mono uppercase tracking-wider transition-colors',
          isProjectsSurface ? 'text-neon' : 'text-text-secondary hover:text-neon',
        ]}
      >
        {isProjectsSurface ? '> ' : ''}{t('nav.projects')}
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const nav = document.getElementById('mobile-nav');
    const hamburger = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    if (!toggle || !nav || !hamburger || !closeIcon) return;

    const controller = new AbortController();
    document.addEventListener('astro:before-swap', () => controller.abort(), { once: true });

    const closeMenu = () => {
      nav.classList.add('hidden');
      hamburger.classList.remove('hidden');
      closeIcon.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    };

    toggle.addEventListener(
      'click',
      () => {
        const isNowOpen = nav.classList.toggle('hidden') === false;
        hamburger.classList.toggle('hidden', isNowOpen);
        closeIcon.classList.toggle('hidden', !isNowOpen);
        toggle.setAttribute('aria-expanded', String(isNowOpen));
      },
      { signal: controller.signal },
    );

    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu, { signal: controller.signal });
    });
  });
</script>
